/* EduTrain Platform Design System v3 - Soft UI Evolution */

page {
  background-color: #F8FAFC;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* ============================================
   COLOR SYSTEM - Semantic Tokens
   ============================================ */
:root {
  /* Primary - Indigo (Parent/Student) */
  --primary: #4F46E5;
  --primary-hover: #4338CA;
  --primary-light: #818CF8;
  --primary-soft: rgba(79, 70, 229, 0.08);
  --primary-medium: rgba(79, 70, 229, 0.12);

  /* Teacher - Emerald */
  --teacher: #059669;
  --teacher-hover: #047857;
  --teacher-light: #34D399;
  --teacher-soft: rgba(5, 150, 105, 0.08);
  --teacher-medium: rgba(5, 150, 105, 0.12);

  /* Admin - Violet */
  --admin: #7C3AED;
  --admin-hover: #6D28D9;
  --admin-light: #A78BFA;
  --admin-soft: rgba(124, 58, 237, 0.08);
  --admin-medium: rgba(124, 58, 237, 0.12);

  /* Surfaces */
  --bg: #F8FAFC;
  --bg-warm: #F7F6F3;
  --surface: #FFFFFF;
  --surface-raised: #FFFFFF;

  /* Text */
  --text-primary: #0F172A;
  --text-secondary: #475569;
  --text-muted: #94A3B8;
  --text-disabled: #CBD5E1;

  /* Borders */
  --border: #E2E8F0;
  --border-light: #F1F5F9;

  /* Semantic */
  --success: #059669;
  --success-soft: rgba(5, 150, 105, 0.1);
  --warning: #D97706;
  --warning-soft: rgba(217, 119, 6, 0.1);
  --danger: #DC2626;
  --danger-soft: rgba(220, 38, 38, 0.1);
  --info: #2563EB;
  --info-soft: rgba(37, 99, 235, 0.1);

  /* Shadows - Colored by role */
  --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
  --shadow-md: 0 2px 8px -2px rgba(0, 0, 0, 0.08), 0 4px 12px -4px rgba(0, 0, 0, 0.04);
  --shadow-lg: 0 4px 16px -4px rgba(0, 0, 0, 0.1), 0 8px 24px -8px rgba(0, 0, 0, 0.06);
  --shadow-primary: 0 2px 8px -2px rgba(79, 70, 229, 0.2), 0 4px 12px -4px rgba(79, 70, 229, 0.1);
  --shadow-teacher: 0 2px 8px -2px rgba(5, 150, 105, 0.2), 0 4px 12px -4px rgba(5, 150, 105, 0.1);
  --shadow-admin: 0 2px 8px -2px rgba(124, 58, 237, 0.2), 0 4px 12px -4px rgba(124, 58, 237, 0.1);

  /* Radii */
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 20rpx;
  --radius-xl: 24rpx;
  --radius-pill: 999rpx;

  /* Spacing */
  --space-1: 8rpx;
  --space-2: 16rpx;
  --space-3: 24rpx;
  --space-4: 32rpx;
  --space-5: 40rpx;
  --space-6: 48rpx;
  --space-8: 64rpx;

  /* Transitions */
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  --duration-fast: 150ms;
  --duration-normal: 250ms;
  --duration-slow: 400ms;
}

/* ============================================
   ANIMATIONS
   ============================================ */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.92);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

@keyframes pulse-dot {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* Stagger entrance - apply to parent containers */
.stagger-1 { animation: fadeInUp 400ms var(--ease-out) 50ms both; }
.stagger-2 { animation: fadeInUp 400ms var(--ease-out) 100ms both; }
.stagger-3 { animation: fadeInUp 400ms var(--ease-out) 150ms both; }
.stagger-4 { animation: fadeInUp 400ms var(--ease-out) 200ms both; }
.stagger-5 { animation: fadeInUp 400ms var(--ease-out) 250ms both; }
.stagger-6 { animation: fadeInUp 400ms var(--ease-out) 300ms both; }

/* ============================================
   TEXT STYLES - Refined Hierarchy
   ============================================ */
.text-primary { color: var(--primary); }
.text-teacher { color: var(--teacher); }
.text-admin { color: var(--admin); }
.text-secondary { color: var(--text-secondary); }
.text-muted { color: var(--text-muted); }
.text-dark { color: var(--text-primary); }
.text-white { color: #FFFFFF; }
.text-success { color: var(--success); }
.text-warning { color: var(--warning); }
.text-danger { color: var(--danger); }

.text-medium { font-weight: 500; }
.text-semibold { font-weight: 600; }
.text-bold { font-weight: 700; }

.text-display {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.03em;
  line-height: 1.15;
}

.text-heading {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.025em;
  line-height: 1.2;
}

.text-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.02em;
  line-height: 1.3;
}

.text-body {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
}

.text-body-sm {
  font-size: 26rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.text-caption {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

.text-overline {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-muted);
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

/* ============================================
   BACKGROUND UTILITIES
   ============================================ */
.bg-primary { background-color: var(--primary); }
.bg-primary-soft { background-color: var(--primary-soft); }
.bg-teacher-soft { background-color: var(--teacher-soft); }
.bg-admin-soft { background-color: var(--admin-soft); }
.bg-surface { background-color: var(--surface); }
.bg-bg { background-color: var(--bg); }
.bg-success-soft { background-color: var(--success-soft); }
.bg-warning-soft { background-color: var(--warning-soft); }
.bg-danger-soft { background-color: var(--danger-soft); }
.bg-info-soft { background-color: var(--info-soft); }

.bg-gradient-soft {
  background: linear-gradient(180deg, #F8FAFC 0%, #F1F5F9 100%);
}

.bg-gradient-primary {
  background: linear-gradient(135deg, #4F46E5 0%, #6366F1 100%);
}

.bg-gradient-teacher {
  background: linear-gradient(135deg, #059669 0%, #10B981 100%);
}

.bg-gradient-admin {
  background: linear-gradient(135deg, #7C3AED 0%, #8B5CF6 100%);
}

/* ============================================
   LAYOUT
   ============================================ */
.container {
  padding: var(--space-3);
  max-width: 900rpx;
  margin: 0 auto;
}

.flex { display: flex; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-column { display: flex; flex-direction: column; }
.flex-wrap { display: flex; flex-wrap: wrap; }
.flex-1 { flex: 1; }
.gap-1 { gap: var(--space-1); }
.gap-2 { gap: var(--space-2); }
.gap-3 { gap: var(--space-3); }

/* ============================================
   CARD SYSTEM - Soft UI with colored shadows
   ============================================ */
.card {
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
  box-shadow: var(--shadow-md);
  border: 1px solid var(--border-light);
  transition: all var(--duration-normal) var(--ease-out);
}

.card:active {
  transform: translateY(1px);
  box-shadow: var(--shadow-sm);
}

.card-elevated {
  box-shadow: var(--shadow-lg);
}

.card-primary {
  box-shadow: var(--shadow-md), var(--shadow-primary);
}

.card-teacher {
  box-shadow: var(--shadow-md), var(--shadow-teacher);
}

.card-admin {
  box-shadow: var(--shadow-md), var(--shadow-admin);
}

/* ============================================
   BUTTON SYSTEM
   ============================================ */
.btn-primary {
  background: var(--primary);
  color: #FFFFFF;
  border-radius: var(--radius-md);
  padding: 26rpx 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: var(--shadow-primary);
  transition: all var(--duration-normal) var(--ease-out);
  border: none;
  line-height: 1;
  text-align: center;
}

.btn-primary:active {
  background: var(--primary-hover);
  transform: scale(0.97);
  box-shadow: var(--shadow-sm);
}

.btn-teacher {
  background: var(--teacher);
  box-shadow: var(--shadow-teacher);
}

.btn-teacher:active {
  background: var(--teacher-hover);
}

.btn-admin {
  background: var(--admin);
  box-shadow: var(--shadow-admin);
}

.btn-admin:active {
  background: var(--admin-hover);
}

.btn-ghost {
  background: transparent;
  color: var(--primary);
  border-radius: var(--radius-md);
  padding: 26rpx 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all var(--duration-normal) var(--ease-out);
}

.btn-ghost:active {
  background: var(--primary-soft);
  transform: scale(0.97);
}

.btn-text {
  background: transparent;
  color: var(--primary);
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: var(--radius-sm);
  transition: all var(--duration-normal) var(--ease-out);
}

.btn-text:active {
  background: var(--primary-soft);
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: var(--radius-md);
  padding: 24rpx 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all var(--duration-normal) var(--ease-out);
}

.btn-outline:active {
  background: var(--primary-soft);
  transform: scale(0.97);
}

.btn-danger {
  background: var(--danger);
  color: #FFFFFF;
  border-radius: var(--radius-md);
  padding: 26rpx 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all var(--duration-normal) var(--ease-out);
}

.btn-danger:active {
  opacity: 0.9;
  transform: scale(0.97);
}

.btn-disabled {
  background: var(--text-disabled);
  color: #FFFFFF;
  box-shadow: none;
  pointer-events: none;
}

/* ============================================
   TAG / BADGE SYSTEM
   ============================================ */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-pill);
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.01em;
}

.tag-primary {
  background: var(--primary-soft);
  color: var(--primary);
}

.tag-teacher {
  background: var(--teacher-soft);
  color: var(--teacher);
}

.tag-admin {
  background: var(--admin-soft);
  color: var(--admin);
}

.tag-success {
  background: var(--success-soft);
  color: var(--success);
}

.tag-warning {
  background: var(--warning-soft);
  color: var(--warning);
}

.tag-danger {
  background: var(--danger-soft);
  color: var(--danger);
}

.tag-muted {
  background: var(--border-light);
  color: var(--text-muted);
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: var(--danger);
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 700;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  box-shadow: 0 2px 8px rgba(220, 38, 38, 0.3);
  border: 2rpx solid var(--surface);
  animation: scaleIn 300ms var(--ease-spring) both;
}

/* Status dot - pulsing indicator */
.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  display: inline-block;
  margin-right: 8rpx;
}

.status-dot.active {
  background: var(--success);
  animation: pulse-dot 2s ease-in-out infinite;
}

.status-dot.warning {
  background: var(--warning);
  animation: pulse-dot 2s ease-in-out infinite;
}

.status-dot.danger {
  background: var(--danger);
  animation: pulse-dot 1.5s ease-in-out infinite;
}

/* ============================================
   ICON SYSTEM - SVG-based containers
   ============================================ */
.icon-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-box {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--duration-normal) var(--ease-out);
}

.icon-box:active {
  transform: scale(0.94);
}

.icon-box-primary {
  background: var(--primary-soft);
  color: var(--primary);
}

.icon-box-teacher {
  background: var(--teacher-soft);
  color: var(--teacher);
}

.icon-box-admin {
  background: var(--admin-soft);
  color: var(--admin);
}

.icon-box-success {
  background: var(--success-soft);
  color: var(--success);
}

.icon-box-warning {
  background: var(--warning-soft);
  color: var(--warning);
}

.icon-box-danger {
  background: var(--danger-soft);
  color: var(--danger);
}

.icon-box-sm {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-lg);
}

.icon-box-lg {
  width: 104rpx;
  height: 104rpx;
  border-radius: 28rpx;
}

.icon-image {
  width: 44rpx;
  height: 44rpx;
}

.icon-image-sm {
  width: 36rpx;
  height: 36rpx;
}

.icon-image-lg {
  width: 52rpx;
  height: 52rpx;
}

/* ============================================
   INPUT SYSTEM
   ============================================ */
.input-wrapper {
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: 28rpx 24rpx;
  border: 2rpx solid var(--border);
  display: flex;
  align-items: center;
  transition: all var(--duration-normal) var(--ease-out);
}

.input-wrapper:focus-within {
  border-color: var(--primary);
  box-shadow: 0 0 0 4rpx var(--primary-soft);
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
  background: transparent;
}

.form-input::placeholder {
  color: var(--text-disabled);
}

.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
  letter-spacing: 0.01em;
}

/* ============================================
   SECTION SYSTEM
   ============================================ */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.02em;
}

.section-more {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-pill);
  background: var(--primary-soft);
  transition: all var(--duration-normal) var(--ease-out);
}

.section-more:active {
  background: var(--primary-medium);
  transform: scale(0.96);
}

/* ============================================
   AVATAR SYSTEM
   ============================================ */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.avatar-primary {
  background: var(--primary);
  box-shadow: var(--shadow-primary);
}

.avatar-teacher {
  background: var(--teacher);
  box-shadow: var(--shadow-teacher);
}

.avatar-admin {
  background: var(--admin);
  box-shadow: var(--shadow-admin);
}

.avatar-gradient {
  background: linear-gradient(135deg, #4F46E5 0%, #6366F1 100%);
  box-shadow: var(--shadow-primary);
}

.avatar-teacher-gradient {
  background: linear-gradient(135deg, #059669 0%, #10B981 100%);
  box-shadow: var(--shadow-teacher);
}

.avatar-admin-gradient {
  background: linear-gradient(135deg, #7C3AED 0%, #8B5CF6 100%);
  box-shadow: var(--shadow-admin);
}

.avatar-sm {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  font-size: 26rpx;
}

.avatar-lg {
  width: 96rpx;
  height: 96rpx;
  border-radius: 26rpx;
  font-size: 36rpx;
}

/* ============================================
   LIST SYSTEM
   ============================================ */
.list-item {
  padding: 24rpx 0;
  border-bottom: 1px solid var(--border-light);
  transition: all var(--duration-normal) var(--ease-out);
}

.list-item:last-child {
  border-bottom: none;
}

.list-item:active {
  background: var(--primary-soft);
  margin: 0 -24rpx;
  padding: 24rpx;
  border-radius: var(--radius-md);
}

/* ============================================
   EMPTY STATE
   ============================================ */
.empty-state {
  text-align: center;
  padding: 100rpx 60rpx;
  background: transparent;
  animation: fadeIn 400ms var(--ease-out) both;
}

.empty-state-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 32rpx;
  background: var(--border-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
}

.empty-state-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  letter-spacing: -0.01em;
}

.empty-state-text {
  font-size: 26rpx;
  color: var(--text-muted);
  line-height: 1.6;
}

/* ============================================
   SKELETON LOADING
   ============================================ */
.skeleton {
  background: linear-gradient(90deg, var(--border-light) 25%, #F8FAFC 50%, var(--border-light) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  border-radius: var(--radius-sm);
}

/* ============================================
   DIVIDER
   ============================================ */
.divider {
  height: 1px;
  background: var(--border-light);
  margin: var(--space-4) 0;
}

/* ============================================
   SPACING UTILITIES
   ============================================ */
.mt-1 { margin-top: var(--space-1); }
.mt-2 { margin-top: var(--space-2); }
.mt-3 { margin-top: var(--space-3); }
.mt-4 { margin-top: var(--space-4); }
.mt-5 { margin-top: var(--space-5); }
.mt-6 { margin-top: var(--space-6); }
.mb-1 { margin-bottom: var(--space-1); }
.mb-2 { margin-bottom: var(--space-2); }
.mb-3 { margin-bottom: var(--space-3); }
.mb-4 { margin-bottom: var(--space-4); }
.mb-5 { margin-bottom: var(--space-5); }
.ml-2 { margin-left: var(--space-2); }
.ml-3 { margin-left: var(--space-3); }
.mr-2 { margin-right: var(--space-2); }
.mr-3 { margin-right: var(--space-3); }
.p-3 { padding: var(--space-3); }
.p-4 { padding: var(--space-4); }
.px-3 { padding-left: var(--space-3); padding-right: var(--space-3); }
.py-3 { padding-top: var(--space-3); padding-bottom: var(--space-3); }

/* Border radius utilities */
.rounded-sm { border-radius: var(--radius-sm); }
.rounded-md { border-radius: var(--radius-md); }
.rounded-lg { border-radius: var(--radius-lg); }
.rounded-xl { border-radius: var(--radius-xl); }
.rounded-pill { border-radius: var(--radius-pill); }

/* ============================================
   INTERACTIVE AFFORDANCE SYSTEM
   Distinguish clickable elements from display-only
   ============================================ */

/* Clickable list item - left accent border + active feedback */
.interactive-item {
  position: relative;
  border-left: 4rpx solid var(--border-light);
  transition: all var(--duration-normal) var(--ease-out);
}

.interactive-item.interactive-primary { border-left-color: rgba(79, 70, 229, 0.25); }
.interactive-item.interactive-teacher { border-left-color: rgba(5, 150, 105, 0.25); }
.interactive-item.interactive-admin  { border-left-color: rgba(124, 58, 237, 0.25); }

.interactive-item:active {
  transform: scale(0.98);
}

.interactive-item.interactive-primary:active {
  border-left-color: var(--primary);
  background: var(--primary-soft);
}
.interactive-item.interactive-teacher:active {
  border-left-color: var(--teacher);
  background: var(--teacher-soft);
}
.interactive-item.interactive-admin:active {
  border-left-color: var(--admin);
  background: var(--admin-soft);
}

/* Right arrow indicator for clickable rows */
.interactive-arrow {
  font-size: 32rpx;
  color: var(--text-disabled);
  margin-left: 12rpx;
  line-height: 1;
  transition: all var(--duration-normal) var(--ease-out);
}

.interactive-item:active .interactive-arrow {
  transform: translateX(4rpx);
}

.interactive-item.interactive-primary:active .interactive-arrow { color: var(--primary); }
.interactive-item.interactive-teacher:active .interactive-arrow { color: var(--teacher); }
.interactive-item.interactive-admin:active .interactive-arrow  { color: var(--admin); }

/* Elevated menu icon - "floating button" feel vs flat stat icon */
.menu-icon-elevated {
  box-shadow: 0 2px 8px -2px rgba(0, 0, 0, 0.12), 0 4px 8px -4px rgba(0, 0, 0, 0.06);
  transition: all var(--duration-normal) var(--ease-out);
}

.menu-icon-elevated:active {
  transform: scale(0.92);

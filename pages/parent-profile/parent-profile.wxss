/* Parent Profile Page v3 - Soft UI Evolution */

.page-container {
  min-height: 100vh;
  background-color: #F8FAFC;
  padding: 24rpx 24rpx 40rpx;
}

/* ============================================
   HEADER
   ============================================ */
.header {
  margin-bottom: 20rpx;
}

.user-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2px 8px -2px rgba(79, 70, 229, 0.08), 0 4px 12px -4px rgba(79, 70, 229, 0.04);
  border: 1px solid rgba(226, 232, 240, 0.5);
  transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
}

.user-card:active {
  transform: scale(0.98);
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
  margin-right: 20rpx;
  letter-spacing: -0.02em;
}

.avatar-gradient {
  background: linear-gradient(135deg, #4F46E5 0%, #6366F1 100%);
  box-shadow: 0 2px 8px -2px rgba(79, 70, 229, 0.3);
}

.avatar-teacher-gradient {
  background: linear-gradient(135deg, #059669 0%, #10B981 100%);
  box-shadow: 0 2px 8px -2px rgba(5, 150, 105, 0.3);
}

.user-detail {
  flex: 1;
}

.user-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #0F172A;
  margin-bottom: 6rpx;
  letter-spacing: -0.02em;
  display: block;
}

.user-phone {
  font-size: 24rpx;
  color: #94A3B8;
  display: block;
}

.arrow {
  font-size: 32rpx;
  color: #CBD5E1;
  line-height: 1;
}

/* ============================================
   STUDENT SECTION
   ============================================ */
.student-section {
  margin-bottom: 24rpx;
}

.student-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2px 8px -2px rgba(0, 0, 0, 0.08), 0 4px 12px -4px rgba(0, 0, 0, 0.04);
  border: 1px solid rgba(226, 232, 240, 0.5);
}

.student-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1px solid #F1F5F9;
}

.student-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.student-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
  margin-right: 16rpx;
}

.student-detail {
  flex: 1;
}

.student-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #0F172A;
  margin-bottom: 4rpx;
  letter-spacing: -0.01em;
  display: block;
}

.student-label {
  font-size: 22rpx;
  color: #94A3B8;
  display: block;
}

.manage-chip {
  font-size: 24rpx;
  color: #4F46E5;
  font-weight: 600;
  padding: 10rpx 20rpx;
  background: rgba(79, 70, 229, 0.08);
  border-radius: 12rpx;
  transition: all 200ms ease;
}

.manage-chip:active {
  background: rgba(79, 70, 229, 0.14);
}

/* ============================================
   MENU LIST
   ============================================ */
.menu-list {
  padding: 8rpx 0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 22rpx 24rpx;
  position: relative;
  transition: all 200ms ease;
}

.menu-item:active {
  background: rgba(79, 70, 229, 0.03);
}

.menu-icon-box {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
}

.menu-label {
  flex: 1;
  font-size: 28rpx;
  color: #0F172A;
  font-weight: 500;
}

.badge {
  position: absolute;
  right: 60rpx;
  top: 50%;
  transform: translateY(-50%);
  background: #DC2626;
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 700;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  box-shadow: 0 2px 8px rgba(220, 38, 38, 0.3);
  border: 2rpx solid #FFFFFF;
}

.menu-arrow {
  font-size: 28rpx;
  color: #CBD5E1;
  line-height: 1;
}

.menu-points {
  font-size: 26rpx;
  color: #D97706;
  font-weight: 600;
  margin-left: auto;
  margin-right: 12rpx;
}

/* ============================================
   LOGOUT
   ============================================ */
.logout-section {
  margin-top: 20rpx;
}

.logout-btn {
  background: #FFFFFF;
  color: #94A3B8;
  padding: 26rpx;
  border-radius: 16rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 2px 8px -2px rgba(0, 0, 0, 0.06);
  border: 1px solid rgba(226, 232, 240, 0.5);
  transition: all 200ms ease;
}

.logout-btn:active {
  background: #F8FAFC;
  transform: scale(0.98);
}

/* ============================================
   NO STUDENT
   ============================================ */
.no-student-section {
  padding: 40rpx 0;
}

.no-student-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 64rpx 32rpx;
  text-align: center;
  box-shadow: 0 4px 16px -4px rgba(0, 0, 0, 0.1);
  border: 1px solid rgba(226, 232, 240, 0.5);
  animation: fadeInUp 500ms cubic-bezier(0.16, 1, 0.3, 1) both;
}

.no-student-icon {
  width: 104rpx;
  height: 104rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
}

.no-student-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0F172A;
  margin-bottom: 10rpx;
  letter-spacing: -0.02em;
  display: block;
}

.no-student-desc {
  font-size: 26rpx;
  color: #94A3B8;
  margin-bottom: 36rpx;
  display: block;
}

.no-student-btn {
  background: linear-gradient(135deg, #4F46E5, #6366F1);
  color: #FFFFFF;
  padding: 24rpx 56rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: inline-block;
  box-shadow: 0 4px 16px -4px rgba(79, 70, 229, 0.4);
  transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
}

.no-student-btn:active {
  transform: scale(0.97);
}

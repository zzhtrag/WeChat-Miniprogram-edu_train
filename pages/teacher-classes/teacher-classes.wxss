.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.tabs {
  display: flex;
  background: #ffffff;
  padding: 0 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #1677ff;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #1677ff;
  border-radius: 2rpx;
}

.tab-content {
  padding: 20rpx;
}

.class-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.class-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  border: 3rpx solid transparent;
}

.class-card.selected {
  border-color: #1677ff;
}

.class-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.class-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f1f1f;
}

.class-course {
  font-size: 24rpx;
  color: #1677ff;
  background: #e6f4ff;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.class-stats {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 0;
  border-top: 2rpx solid #f0f0f0;
  border-bottom: 2rpx solid #f0f0f0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 8rpx;
}

.stat-value.highlight {
  color: #52c41a;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
}

.class-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24rpx;
}

.last-lesson {
  font-size: 24rpx;
  color: #999999;
}

.view-detail {
  font-size: 24rpx;
  color: #1677ff;
}

.student-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.student-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
}

.student-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.student-info {
  flex: 1;
}

.student-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 10rpx;
}

.student-stats {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.last-active {
  font-size: 22rpx;
  color: #999999;
}

.student-actions {
  margin-left: 20rpx;
}

.action-btn {
  background: linear-gradient(135deg, #1677ff 0%, #0958d9 100%);
  color: #ffffff;
  padding: 14rpx 28rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
}

/* Enrollment Page - Soft UI Evolution (consistent with app design system) */
.page-container {
  min-height: 100vh;
  background-color: #F8FAFC;
}

/* ============================================
   HEADER - Matches login/admin gradient
   ============================================ */
.header {
  position: relative;
  padding: 100rpx 48rpx 60rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, #4F46E5 0%, #6366F1 50%, #818CF8 100%);
  border-radius: 0 0 48rpx 48rpx;
}

.header-bg::after {
  content: '';
  position: absolute;
  top: -40%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.header-content {
  position: relative;
  display: flex;
  flex-direction: column;
  animation: fadeInUp 500ms cubic-bezier(0.16, 1, 0.3, 1) both;
}

.logo-area {
  display: flex;
  align-items: center;
}

.logo-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.15);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.logo-image {
  width: 76rpx;
  height: 76rpx;
  flex-shrink: 0;
}

.logo-text {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 37rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: -0.03em;
  margin-bottom: 4rpx;
}

.header-desc {
  font-size: 25rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

/* ============================================
   FORM CARD
   ============================================ */
.form-card {
  margin: -24rpx 32rpx 0;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 4px 16px -4px rgba(79, 70, 229, 0.1), 0 8px 24px -8px rgba(79, 70, 229, 0.06);
  border: 1px solid rgba(226, 232, 240, 0.6);
  position: relative;
  z-index: 2;
  animation: fadeInUp 500ms cubic-bezier(0.16, 1, 0.3, 1) 100ms both;
}

/* ============================================
   SECTION HEADER with icon
   ============================================ */
.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.section-header-spacing {
  margin-top: 44rpx;
}

.section-icon-box {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
}

.icon-box-primary {
  background: rgba(79, 70, 229, 0.1);
}

.icon-box-accent {
  background: rgba(245, 158, 11, 0.1);
}

.section-icon {
  width: 26rpx;
  height: 26rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0F172A;
  letter-spacing: -0.01em;
}

/* ============================================
   FORM ITEMS
   ============================================ */
.form-item {
  margin-bottom: 24rpx;
}

.form-row {
  display: flex;
  gap: 16rpx;
}

.form-item-half {
  flex: 1;
  min-width: 0;
}

.form-label {
  font-size: 26rpx;
  color: #64748B;
  font-weight: 500;
  margin-bottom: 10rpx;
  display: block;
}

.required {
  color: #EF4444;
  font-weight: 600;
}

.input-wrapper {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 96rpx;
  border: 2rpx solid #E2E8F0;
  display: flex;
  align-items: center;
  transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
}

.input-wrapper:focus-within {
  border-color: #4F46E5;
  background: #FFFFFF;
  box-shadow: 0 0 0 4rpx rgba(79, 70, 229, 0.08);
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: #0F172A;
  background: transparent;
  height: 96rpx;
}

.form-input::placeholder {
  color: #CBD5E1;
}

.form-input-phone {
  flex: 1;
}

.input-prefix {
  font-size: 28rpx;
  font-weight: 600;
  color: #475569;
  margin-right: 16rpx;
}

.input-divider {
  width: 2rpx;
  height: 32rpx;
  background: #E2E8F0;
  margin-right: 20rpx;
}

/* Picker */
.picker-trigger {
  cursor: pointer;
}

.picker-value-text {
  flex: 1;
  font-size: 30rpx;
  color: #0F172A;
}

.picker-placeholder {
  flex: 1;
  font-size: 30rpx;
  color: #CBD5E1;
}

.picker-chevron {
  font-size: 32rpx;
  color: #CBD5E1;
  margin-left: 8rpx;
}

/* ============================================
   SUBMIT BUTTON
   ============================================ */
.submit-btn {
  margin-top: 48rpx;
  background: linear-gradient(135deg, #4F46E5 0%, #6366F1 100%);
  color: #FFFFFF;
  border-radius: 16rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 16px -4px rgba(79, 70, 229, 0.4);
  border: none;
  padding: 0;
  line-height: 1;
  transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
}

.submit-btn:active {
  transform: scale(0.97);
  box-shadow: 0 2px 8px -2px rgba(79, 70, 229, 0.3);
}

.submit-btn-text {
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 0.08em;
}

.btn-disabled {
  background: #E2E8F0;
  box-shadow: none;
  pointer-events: none;
}

.btn-disabled .submit-btn-text { color: #94A3B8; }

.form-hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 20rpx;
}

/* ============================================
   RESULT CARD
   ============================================ */
.result-card {
  margin: -24rpx 32rpx 0;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 56rpx 32rpx 40rpx;
  box-shadow: 0 4px 16px -4px rgba(5, 150, 105, 0.12), 0 8px 24px -8px rgba(5, 150, 105, 0.06);
  border: 1px solid rgba(226, 232, 240, 0.6);
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 2;
  animation: fadeInUp 500ms cubic-bezier(0.16, 1, 0.3, 1) both;
}

.result-icon-wrapper {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #059669, #10B981);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 6px 20px -4px rgba(5, 150, 105, 0.4);
  animation: scaleIn 400ms cubic-bezier(0.34, 1.56, 0.64, 1) 100ms both;
}

.result-icon {
  font-size: 52rpx;
  color: #FFFFFF;
  font-weight: 700;
}

.result-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0F172A;
  margin-bottom: 8rpx;
  animation: fadeInUp 400ms cubic-bezier(0.16, 1, 0.3, 1) 200ms both;
}

.result-desc {
  font-size: 24rpx;
  color: #94A3B8;
  margin-bottom: 40rpx;
  animation: fadeInUp 400ms cubic-bezier(0.16, 1, 0.3, 1) 250ms both;
}

/* Code Card - more prominent */
.code-card {
  width: 100%;
  background: linear-gradient(135deg, rgba(79, 70, 229, 0.04), rgba(99, 102, 241, 0.06));
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  border: 2rpx solid rgba(79, 70, 229, 0.15);
  margin-bottom: 32rpx;
  animation: fadeInUp 400ms cubic-bezier(0.16, 1, 0.3, 1) 300ms both;
}

.code-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.code-label {
  font-size: 22rpx;
  color: #94A3B8;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.copy-btn {
  padding: 10rpx 20rpx;
  background: rgba(79, 70, 229, 0.1);
  border-radius: 10rpx;
  transition: all 200ms ease;
}

.copy-btn:active {
  transform: scale(0.94);
  background: rgba(79, 70, 229, 0.18);
}

.copy-text {
  font-size: 24rpx;
  color: #4F46E5;
  font-weight: 600;
}

.code-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #4F46E5;
  letter-spacing: 0.3em;
  text-align: center;
  display: block;
  margin-bottom: 12rpx;
}

.code-expire {
  font-size: 22rpx;
  color: #94A3B8;
  text-align: center;
  display: block;
}

/* ============================================
   STATUS FLOW - Enhanced visual weight
   ============================================ */
.status-flow {
  display: flex;
  align-items: flex-start;
  width: 100%;
  margin-bottom: 40rpx;
  padding: 0 8rpx;
  animation: fadeInUp 400ms cubic-bezier(0.16, 1, 0.3, 1) 350ms both;
}

.flow-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  width: 80rpx;
}

.flow-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #F1F5F9;
  border: 3rpx solid #E2E8F0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
  transition: all 300ms ease;
}

.flow-dot-inner {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: transparent;
  transition: all 300ms ease;
}

.flow-step.active .flow-dot {
  background: #4F46E5;
  border-color: #4F46E5;
  box-shadow: 0 0 0 6rpx rgba(79, 70, 229, 0.12);
}

.flow-step.active .flow-dot-inner {
  background: #FFFFFF;
}

.flow-label {
  font-size: 22rpx;
  color: #CBD5E1;
  font-weight: 500;
  transition: all 300ms ease;
}

.flow-step.active .flow-label {
  color: #4F46E5;
  font-weight: 700;
}

.flow-line {
  flex: 1;
  height: 6rpx;
  background: #E2E8F0;
  margin: 17rpx 8rpx 0;
  border-radius: 3rpx;
  transition: background 300ms ease;
}

/* ============================================
   RESULT ACTIONS
   ============================================ */
.result-actions {
  width: 100%;
  animation: fadeInUp 400ms cubic-bezier(0.16, 1, 0.3, 1) 400ms both;
}

.primary-action-btn {
  width: 100%;
  background: linear-gradient(135deg, #4F46E5 0%, #6366F1 100%);
  border-radius: 16rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 16px -4px rgba(79, 70, 229, 0.4);
  border: none;
  padding: 0;
  line-height: 1;
  margin-bottom: 16rpx;
  transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
}

.primary-action-btn:active {
  transform: scale(0.97);
}

.primary-action-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 0.04em;
}

.secondary-action-btn {
  width: 100%;
  background: #F8FAFC;
  border-radius: 16rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #E2E8F0;
  padding: 0;
  line-height: 1;
  transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
}

.secondary-action-btn:active {
  transform: scale(0.97);
  background: #F1F5F9;
}

.secondary-action-text {
  font-size: 28rpx;
  color: #475569;
  font-weight: 600;
}

/* ============================================
   ANIMATIONS
   ============================================ */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.5);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

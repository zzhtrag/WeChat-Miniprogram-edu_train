.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

.info-card {
  background: #ffffff;
  margin: 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.class-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.class-meta {
  font-size: 26rpx;
  color: #999;
}

.search-bar {
  margin: 0 30rpx 20rpx;
}

.search-input {
  background: #fff;
  border-radius: 40rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section {
  margin: 0 30rpx 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

.student-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.student-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.student-item.disabled {
  opacity: 0.6;
}

.student-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #722ed1, #eb8cff);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.student-info {
  flex: 1;
}

.student-name {
  font-size: 30rpx;
  color: #333;
  display: block;
}

.student-no {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.student-status.enrolled {
  font-size: 24rpx;
  color: #52c41a;
  background: #e6f7e6;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #d9d9d9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
}

.checkbox.checked {
  background: #722ed1;
  border-color: #722ed1;
}

.empty-tips {
  text-align: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: #999;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.selected-count {
  font-size: 28rpx;
  color: #666;
}

.confirm-btn {
  background: linear-gradient(135deg, #722ed1, #eb8cff);
  color: #fff;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
}

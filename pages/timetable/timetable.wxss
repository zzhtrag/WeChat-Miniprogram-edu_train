/* Timetable Page v3 - Soft UI Evolution */

.page-container {
  min-height: 100vh;
  background-color: #F8FAFC;
  padding: 24rpx 24rpx 40rpx;
}

/* ============================================
   NO STUDENT
   ============================================ */
.no-student {
  padding: 120rpx 0;
}

.no-student-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 64rpx 32rpx;
  text-align: center;
  box-shadow: 0 4px 16px -4px rgba(0, 0, 0, 0.1);
  border: 1px solid rgba(226, 232, 240, 0.5);
  animation: fadeInUp 500ms cubic-bezier(0.16, 1, 0.3, 1) both;
}

.no-student-icon {
  width: 104rpx;
  height: 104rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
}

.no-student-text {
  font-size: 28rpx;
  color: #94A3B8;
  margin-bottom: 32rpx;
  display: block;
}

.no-student-btn {
  background: linear-gradient(135deg, #4F46E5, #6366F1);
  color: #FFFFFF;
  padding: 24rpx 56rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: inline-block;
  box-shadow: 0 4px 16px -4px rgba(79, 70, 229, 0.4);
  transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
}

.no-student-btn:active {
  transform: scale(0.97);
}

/* ============================================
   CALENDAR HEADER
   ============================================ */
.calendar-header {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2px 8px -2px rgba(0, 0, 0, 0.08);
  border: 1px solid rgba(226, 232, 240, 0.5);
}

.month-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
}

.nav-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: #F8FAFC;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 200ms ease;
  border: 1px solid #E2E8F0;
}

.nav-btn:active {
  background: #F1F5F9;
  transform: scale(0.94);
}

.nav-arrow {
  font-size: 36rpx;
  color: #475569;
  line-height: 1;
  font-weight: 500;
}

.month-info {
  min-width: 200rpx;
  text-align: center;
}

.month-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0F172A;
  letter-spacing: -0.02em;
}

/* ============================================
   WEEK HEADER
   ============================================ */
.week-header {
  display: flex;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 18rpx 12rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2px 8px -2px rgba(0, 0, 0, 0.08);
  border: 1px solid rgba(226, 232, 240, 0.5);
}

.week-day {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #94A3B8;
  font-weight: 600;
}

/* ============================================
   CALENDAR GRID
   ============================================ */
.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 16rpx 8rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2px 8px -2px rgba(0, 0, 0, 0.08);
  border: 1px solid rgba(226, 232, 240, 0.5);
}

.day-cell {
  width: 14.28%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 14rpx 0;
  position: relative;
  transition: all 200ms ease;
}

.day-cell:active {
  transform: scale(0.94);
}

.day-num {
  font-size: 26rpx;
  color: #0F172A;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-weight: 500;
  transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
}

.day-cell.other-month .day-num {
  color: #CBD5E1;
}

.day-cell.today .day-num {
  background: rgba(79, 70, 229, 0.1);
  color: #4F46E5;
  font-weight: 700;
}

.day-cell.selected .day-num {
  background: linear-gradient(135deg, #4F46E5, #6366F1);
  color: #FFFFFF;
  font-weight: 700;
  box-shadow: 0 2px 8px -2px rgba(79, 70, 229, 0.3);
}

.course-dot {
  width: 8rpx;
  height: 8rpx;
  background: #4F46E5;
  border-radius: 50%;
  margin-top: 6rpx;
}

.day-cell.selected .course-dot {
  background: #FFFFFF;
}

/* ============================================
   SCHEDULE SECTION
   ============================================ */
.schedule-section {
  margin-bottom: 8rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0F172A;
  letter-spacing: -0.02em;
}

.section-count {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(79, 70, 229, 0.08);
}

.count-text {
  font-size: 22rpx;
  color: #4F46E5;
  font-weight: 600;
}

/* ============================================
   SCHEDULE LIST - Timeline style
   ============================================ */
.schedule-list {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2px 8px -2px rgba(0, 0, 0, 0.08);
  border: 1px solid rgba(226, 232, 240, 0.5);
}

.schedule-card {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  border-bottom: 1px solid #F1F5F9;
  transition: all 200ms ease;
}

.schedule-card:last-child {
  border-bottom: none;
}

.schedule-card:active {
  background: rgba(79, 70, 229, 0.03);
}

.schedule-time-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 16rpx;
  min-width: 96rpx;
  padding: 14rpx 16rpx;
  background: rgba(79, 70, 229, 0.06);
  border-radius: 14rpx;
}

.time-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #4F46E5;
  letter-spacing: -0.01em;
}

.time-text.time-end {
  font-weight: 500;
  color: #94A3B8;
  margin-top: 4rpx;
}

.schedule-line {
  width: 4rpx;
  height: 40rpx;
  background: linear-gradient(180deg, #4F46E5, #818CF8);
  border-radius: 2rpx;
  margin-right: 20rpx;
  margin-top: 8rpx;
  opacity: 0.3;
}

.schedule-content {
  flex: 1;
}

.schedule-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #0F172A;
  margin-bottom: 6rpx;
  letter-spacing: -0.01em;
  display: block;
}

.schedule-info {
  font-size: 24rpx;
  color: #64748B;
  margin-bottom: 4rpx;
  display: block;
}

.schedule-room {
  font-size: 22rpx;
  color: #CBD5E1;
  display: block;
}

/* ============================================
   EMPTY STATE
   ============================================ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 32rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 2px 8px -2px rgba(0, 0, 0, 0.08);
  border: 1px solid rgba(226, 232, 240, 0.5);
}

.empty-state-icon {
  margin-bottom: 20rpx;
}

.empty-state-title {
  font-size: 26rpx;
  color: #94A3B8;
  font-weight: 500;
}

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.info-card {
  background: #fff;
  margin: 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.assignment-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f1f1f;
  flex: 1;
  margin-right: 20rpx;
}

.status-badge {
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
  white-space: nowrap;
}

.meta-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.meta-row:last-child {
  margin-bottom: 0;
}

.meta-item {
  display: flex;
  align-items: center;
  margin-right: 40rpx;
}

.meta-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 12rpx;
}

.meta-value {
  font-size: 24rpx;
  color: #333;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 20rpx;
}

.content-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
}

/* Stats card */
.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: #fff;
  margin: 30rpx;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-value.submitted {
  color: #1677ff;
}

.stat-value.graded {
  color: #52c41a;
}

.stat-value.pending {
  color: #999;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #f0f0f0;
}

/* Submission list */
.submission-list {
  display: flex;
  flex-direction: column;
}

.submission-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.submission-item:last-child {
  border-bottom: none;
}

.submission-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.student-avatar-placeholder {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1677ff, #69b1ff);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.student-detail {
  flex: 1;
}

.student-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 6rpx;
}

.student-meta {
  font-size: 22rpx;
  color: #999;
}

.submission-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.status-tag.status-submitted {
  background: #e6f4ff;
  color: #1677ff;
}

.status-tag.status-graded {
  background: #f6ffed;
  color: #52c41a;
}

.status-tag.status-late {
  background: #fff7e6;
  color: #fa8c16;
}

.status-tag.status-pending {
  background: #f5f5f5;
  color: #999;
}

.score-display {
  font-size: 26rpx;
  font-weight: 600;
  color: #52c41a;
}

/* Empty state */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* Bottom action */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.grade-all-btn {
  background: linear-gradient(135deg, #1677ff 0%, #0958d9 100%);
  color: #fff;
  text-align: center;
  padding: 28rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
}

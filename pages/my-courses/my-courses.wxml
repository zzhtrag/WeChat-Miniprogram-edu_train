<view class="page-container">
  <!-- 未选择学生 -->
  <view class="no-student" wx:if="{{!currentStudent}}">
    <view class="no-student-card">
      <view class="no-student-icon">📚</view>
      <view class="no-student-text">暂无关联学生</view>
    </view>
  </view>

  <!-- 课程列表 -->
  <view class="course-list" wx:elif="{{courses.length > 0}}">
    <view class="course-card interactive-item interactive-primary" wx:for="{{courses}}" wx:key="classId" bindtap="viewCourse" data-classid="{{item.classId}}">
      <view class="course-header">
        <view class="course-subject">{{item.subject}}</view>
      </view>
      <view class="course-name">{{item.name}}</view>
      <view class="course-info">
        <view class="info-item">
          <view class="info-icon-wrapper">👨‍🏫</view>
          <view class="info-text">{{item.teacherName}}</view>
        </view>
        <view class="info-item">
          <view class="info-icon-wrapper">📍</view>
          <view class="info-text">{{item.room}}</view>
        </view>
        <view class="info-item">
          <view class="info-icon-wrapper">👥</view>
          <view class="info-text">{{item.studentCount}}/{{item.capacity}}</view>
        </view>
      </view>
      <view class="course-schedule" wx:if="{{item.nextSchedule}}">
        <view class="schedule-icon-wrapper">📅</view>
        <view class="schedule-text">下次课：{{item.nextSchedule.weekDay}} {{item.nextSchedule.date}} {{item.nextSchedule.time}}</view>
      </view>
      <view class="course-footer">
        <view class="schedule-time">{{item.schedule}}</view>
        <view class="view-more">查看详情</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <view class="empty-icon">📚</view>
    <view class="empty-title">暂无在读课程</view>
    <view class="empty-text">去选课中心查看可用课程</view>
    <view class="empty-btn">去选课</view>
  </view>
</view>

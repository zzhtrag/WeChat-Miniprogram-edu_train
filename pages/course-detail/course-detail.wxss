.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 信息卡片 */
.info-card {
  background: #ffffff;
  margin: 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 课程头部 */
.course-header {
  display: flex;
  align-items: flex-start;
}

.course-icon-bg {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #722ed1, #eb8cff);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
  flex-shrink: 0;
}

.course-icon {
  font-size: 56rpx;
}

.course-main-info {
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.course-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.status-tag.active {
  background: #e6f7e6;
  color: #52c41a;
}

.status-tag.inactive {
  background: #f5f5f5;
  color: #999;
}

.course-subject {
  font-size: 28rpx;
  color: #666;
}

.course-desc {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f5f5f5;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 区块标题 */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f5f5f5;
  display: flex;
  align-items: center;
}

.title-count {
  font-size: 24rpx;
  font-weight: normal;
  color: #999;
  margin-left: 8rpx;
}

/* 教师信息 */
.teacher-info {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fafafa;
  border-radius: 12rpx;
}

.teacher-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.teacher-avatar image {
  width: 100%;
  height: 100%;
}

.teacher-details {
  flex: 1;
  min-width: 0;
}

.teacher-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.teacher-meta {
  margin-bottom: 8rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #999;
  margin-right: 16rpx;
}

.teacher-subjects {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.subject-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  background: #f0e6ff;
  color: #722ed1;
}

/* 详情网格 */
.detail-grid {
  display: flex;
  flex-wrap: wrap;
}

.detail-item {
  width: 50%;
  margin-bottom: 24rpx;
}

.detail-item.full-width {
  width: 100%;
}

.detail-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.detail-value {
  display: block;
  font-size: 28rpx;
  color: #333;
}

/* 满员进度条 */
.capacity-bar-wrapper {
  margin-top: 16rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f5f5f5;
}

.capacity-bar {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.capacity-fill {
  height: 100%;
  background: linear-gradient(135deg, #722ed1, #b37feb);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.capacity-text {
  font-size: 24rpx;
  color: #999;
}

/* 学员列表 */
.student-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.student-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fafafa;
  border-radius: 12rpx;
}

.student-avatar-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #00cccc, #00aaff);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

.student-details {
  flex: 1;
  min-width: 0;
}

.student-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.student-no {
  font-size: 24rpx;
  color: #999;
}

.student-parent {
  text-align: right;
  flex-shrink: 0;
}

.parent-label {
  font-size: 22rpx;
  color: #999;
  margin-right: 8rpx;
}

.parent-name {
  font-size: 24rpx;
  color: #666;
}

/* 课程安排 */
.schedule-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.schedule-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fafafa;
  border-radius: 12rpx;
}

.schedule-date {
  width: 100rpx;
  text-align: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.day-text {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #722ed1;
}

.date-text {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.schedule-time {
  flex: 1;
  min-width: 0;
}

.time-range {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.room-text {
  font-size: 22rpx;
  color: #999;
}

.schedule-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.schedule-status.scheduled {
  background: #e6f7ff;
  color: #1890ff;
}

.schedule-status.completed {
  background: #e6f7e6;
  color: #52c41a;
}

.schedule-status.cancelled {
  background: #f5f5f5;
  color: #999;
}

/* 空信息 */
.empty-info {
  padding: 40rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  font-size: 28rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

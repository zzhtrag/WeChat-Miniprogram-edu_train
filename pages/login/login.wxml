<view class="page-container">
  <!-- Top gradient header -->
  <view class="login-header">
    <view class="header-bg"></view>
    <view class="logo-area" bindtap="onLogoTap">
      <view class="logo-icon">
        <image class="logo-image" src="/svg/logo.svg" mode="aspectFit"/>
      </view>
      <view class="logo-text">
        <text class="app-name">XingXing</text>
        <text class="app-desc">星星艺术培训中心</text>
      </view>
    </view>
  </view>

  <!-- Login card -->
  <view class="login-card">
    <!-- Tab bar -->
    <view class="tab-bar">
      <view class="tab-item {{loginType === 'password' ? 'active' : ''}}" bindtap="switchLoginType" data-type="password">
        <text class="tab-text">密码登录</text>
        <view class="tab-indicator" wx:if="{{loginType === 'password'}}"></view>
      </view>
      <view class="tab-item {{loginType === 'code' ? 'active' : ''}}" bindtap="switchLoginType" data-type="code">
        <text class="tab-text">验证码登录</text>
        <view class="tab-indicator" wx:if="{{loginType === 'code'}}"></view>
      </view>
    </view>

    <!-- Form -->
    <view class="form-section">
      <!-- Phone -->
      <view class="form-item">
        <text class="form-label">手机号</text>
        <view class="input-wrapper">
          <text class="input-prefix">+86</text>
          <view class="input-divider"></view>
          <input class="form-input" type="number" placeholder="请输入手机号" maxlength="11" value="{{phone}}" bindinput="onPhoneInput"/>
        </view>
      </view>

      <!-- Password -->
      <view class="form-item" wx:if="{{loginType === 'password'}}">
        <text class="form-label">密码</text>
        <view class="input-wrapper">
          <input class="form-input" type="{{showPassword ? 'text' : 'password'}}" placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput"/>
          <view class="input-suffix" bindtap="togglePassword">
            <text class="suffix-text">{{showPassword ? '隐藏' : '显示'}}</text>
          </view>
        </view>
      </view>

      <!-- Code -->
      <view class="form-item" wx:if="{{loginType === 'code'}}">
        <text class="form-label">验证码</text>
        <view class="input-wrapper">
          <input class="form-input" type="number" placeholder="请输入验证码" maxlength="6" value="{{code}}" bindinput="onCodeInput"/>
          <view class="code-btn {{counting ? 'code-btn-disabled' : ''}}" bindtap="sendCode">
            <text class="code-text">{{counting ? countDown + 's' : '获取验证码'}}</text>
          </view>
        </view>
      </view>

      <!-- Actions -->
      <view class="form-actions" wx:if="{{loginType === 'password'}}">
        <view class="remember-me" bindtap="toggleRemember">
          <view class="checkbox {{remember ? 'checkbox-checked' : ''}}">
            <text class="checkbox-icon" wx:if="{{remember}}">✓</text>
          </view>
          <text class="remember-text">记住密码</text>
        </view>
        <text class="forgot-link" bindtap="goToForgotPassword">忘记密码？</text>
      </view>

      <!-- Login button -->
      <button class="login-btn {{loading || !agreed ? 'btn-disabled' : ''}}" bindtap="doLogin" disabled="{{loading || !agreed}}">
        <text class="login-btn-text">{{loading ? '登录中...' : '登 录'}}</text>
      </button>

      <!-- Agreement -->
      <view class="agreement">
        <view class="checkbox checkbox-sm {{agreed ? 'checkbox-checked' : ''}}" bindtap="toggleAgree">
          <text class="checkbox-icon checkbox-icon-sm" wx:if="{{agreed}}">✓</text>
        </view>
        <text class="agreement-text">我已阅读并同意</text>
        <text class="agreement-link" bindtap="viewAgreement" data-type="user">用户协议</text>
        <text class="agreement-text">和</text>
        <text class="agreement-link" bindtap="viewAgreement" data-type="privacy">隐私政策</text>
      </view>
    </view>

    <!-- WeChat quick login divider (暂时隐藏)
    <view class="divider-section">
      <view class="divider-line"></view>
      <text class="divider-text">其他登录方式</text>
      <view class="divider-line"></view>
    </view>
    -->

    <!-- WeChat phone number quick login (暂时隐藏)
    <button class="wx-login-btn" open-type="getPhoneNumber" bindgetphonenumber="onWxPhoneLogin" disabled="{{!agreed || wxLoading}}">
      <image class="wx-login-icon" src="/svg/icon-wechat.svg" mode="aspectFit"/>
      <text class="wx-login-text">{{wxLoading ? '登录中...' : '微信手机号快捷登录'}}</text>
    </button>
    -->
  </view>

  <!-- Bottom links -->
  <view class="bottom-links">
    <view class="link-item" bindtap="goToEnrollment">
      <view class="link-icon-wrapper link-icon-enrollment">
        <image class="link-icon-svg" src="/svg/icon-enrollment.svg" mode="aspectFit"/>
      </view>
      <view class="link-text-group">
        <text class="link-title">在线报名</text>
        <text class="link-desc">填写信息，完成课程报名</text>
      </view>
      <text class="link-arrow">›</text>
    </view>
    <view class="link-divider"></view>
    <view class="link-item" bindtap="goToEnrollmentStatus">
      <view class="link-icon-wrapper link-icon-status">
        <image class="link-icon-svg" src="/svg/icon-progress.svg" mode="aspectFit"/>
      </view>
      <view class="link-text-group">
        <text class="link-title">报名查询</text>
        <text class="link-desc">查询报名状态和进度</text>
      </view>
      <text class="link-arrow">›</text>
    </view>
  </view>
</view>

<!-- Role selection bottom sheet -->
<view class="role-modal" wx:if="{{showRoleModal}}">
  <view class="role-mask" bindtap="closeRoleModal"></view>
  <view class="role-sheet">
    <view class="role-sheet-handle"></view>
    <view class="role-sheet-header">
      <text class="role-sheet-title">选择登录身份</text>
    </view>

    <view class="role-list">
      <view class="role-card {{selectedRole === item.value ? 'role-card-active' : ''}} role-card-{{item.value}}"
            wx:for="{{availableRoles}}" wx:key="value"
            bindtap="selectRole" data-role="{{item.value}}">
        <view class="role-icon-wrapper role-icon-{{item.value}}">
          <text class="role-icon-text">{{item.value === 'admin' ? 'A' : item.value === 'teacher' ? 'T' : 'P'}}</text>
        </view>
        <view class="role-info">
          <text class="role-name">{{item.name}}</text>
          <text class="role-desc">{{item.value === 'admin' ? '管理教师、学员和课程' : item.value === 'teacher' ? '查看课表和批改作业' : '查看孩子课程和作业'}}</text>
        </view>
        <view class="role-check" wx:if="{{selectedRole === item.value}}">
          <text class="role-check-icon">✓</text>
        </view>
      </view>
    </view>

    <button class="confirm-btn confirm-btn-{{selectedRole}}" bindtap="confirmRole">确认登录</button>
  </view>
</view>

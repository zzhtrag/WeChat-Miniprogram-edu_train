/* 教师消息页面样式 */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 顶部统计 */
.header {
  background: linear-gradient(135deg, #059669 0%, #0099cc 100%);
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.stats {
  display: flex;
  align-items: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 30rpx;
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.stat-num.unread {
  color: #ffeb3b;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

.header-actions {
  display: flex;
}

.mark-read-btn {
  font-size: 26rpx;
  color: #fff;
  padding: 10rpx 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 30rpx;
}

/* 消息列表 */
.message-list {
  padding: 20rpx;
}

.message-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.message-item.unread {
  background: linear-gradient(135deg, #e3f2fd 0%, #f5f5f5 100%);
  border-left: 6rpx solid #059669;
}

.message-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.message-icon.icon-system {
  background: #e3f2fd;
}

.message-icon.icon-parent {
  background: #fce4ec;
}

.message-icon.icon-task {
  background: #fff3e0;
}

.message-content {
  flex: 1;
  overflow: hidden;
}

.message-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.message-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.unread-dot {
  width: 16rpx;
  height: 16rpx;
  background: #ff4757;
  border-radius: 50%;
  margin-left: 16rpx;
}

.message-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.message-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.message-sender {
  font-size: 24rpx;
  color: #999;
}

.message-time {
  font-size: 24rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 26rpx;
  color: #999999;
  padding: 0 10rpx 16rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 28rpx;
  color: #333333;
}

.setting-right {
  display: flex;
  align-items: center;
}

.setting-value {
  font-size: 26rpx;
  color: #999999;
  margin-right: 10rpx;
}

.setting-arrow {
  font-size: 32rpx;
  color: #cccccc;
}

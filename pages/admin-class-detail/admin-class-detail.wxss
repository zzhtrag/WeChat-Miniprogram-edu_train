.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 基本信息卡片 */
.info-card {
  background: #ffffff;
  margin: 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.class-header {
  display: flex;
  align-items: flex-start;
}

.class-icon-bg {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #722ed1, #eb8cff);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
}

.class-icon {
  font-size: 56rpx;
}

.class-main-info {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
}

.status-tag {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.status-tag.active {
  background: #e6f7e6;
  color: #52c41a;
}

.status-tag.inactive {
  background: #f5f5f5;
  color: #999;
}

.class-course {
  font-size: 28rpx;
  color: #666;
}

.more-btn {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx 20rpx;
}

/* 详细信息卡片 */
.detail-card {
  background: #ffffff;
  margin: 0 30rpx 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.detail-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f5f5f5;
  display: flex;
  align-items: center;
}

.title-count {
  font-size: 24rpx;
  font-weight: normal;
  color: #999;
  margin-left: 8rpx;
}

.detail-grid {
  display: flex;
  flex-wrap: wrap;
}

.detail-item {
  width: 50%;
  margin-bottom: 24rpx;
}

.detail-item.full-width {
  width: 100%;
}

.detail-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.detail-value {
  display: block;
  font-size: 28rpx;
  color: #333;
}

/* 教师信息 */
.teacher-info {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fafafa;
  border-radius: 12rpx;
  border-left: 4rpx solid rgba(124, 58, 237, 0.25);
  transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
}

.teacher-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 24rpx;
}

.teacher-avatar image {
  width: 100%;
  height: 100%;
}

.teacher-details {
  flex: 1;
}

.teacher-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.teacher-meta {
  display: flex;
  gap: 16rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #999;
}

.arrow-icon {
  font-size: 28rpx;
  color: #999;
}

.teacher-info:active {
  border-left-color: #7C3AED;
  background: rgba(124, 58, 237, 0.03);
  transform: scale(0.98);
}

.student-item:active {
  border-left-color: #7C3AED;
  background: rgba(124, 58, 237, 0.03);
  transform: scale(0.98);
}

/* 课程简介 */
.course-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 学员列表 */
.student-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.student-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fafafa;
  border-radius: 12rpx;
  border-left: 4rpx solid rgba(124, 58, 237, 0.25);
  transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
}

.student-avatar-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7C3AED, #00aaff);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.avatar-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

.student-details {
  flex: 1;
}

.student-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.student-no {
  font-size: 24rpx;
  color: #999;
}

/* 课程安排 */
.schedule-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.schedule-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  border-left: none;
}

.schedule-date {
  width: 100rpx;
  text-align: center;
  margin-right: 24rpx;
}

.day-text {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #722ed1;
}

.date-text {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.schedule-time {
  flex: 1;
}

.time-range {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.duration-text {
  font-size: 22rpx;
  color: #999;
}

.schedule-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.schedule-status.scheduled {
  background: #e6f7ff;
  color: #1890ff;
}

.schedule-status.completed {
  background: #e6f7e6;
  color: #52c41a;
}

.schedule-status.cancelled {
  background: #f5f5f5;
  color: #999;
}

/* 空状态 */
.empty-info {
  padding: 40rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

/* 底部按钮 */
.bottom-actions {
  padding: 30rpx;
}

.btn-edit {
  width: 100%;
  background: #722ed1;
  color: #ffffff;
  border-radius: 44rpx;
  padding: 28rpx;
  font-size: 30rpx;
  border: none;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  font-size: 28rpx;
  color: #999;
}

/* pages/admin-announcement-edit/admin-announcement-edit.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 200rpx;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 表单区块 */
.form-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 2rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.form-label.required::before {
  content: '*';
  color: #ff4d4f;
  margin-right: 8rpx;
}

.form-input {
  height: 80rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.form-input.error {
  border: 2rpx solid #ff4d4f;
}

.form-textarea {
  min-height: 240rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.form-textarea.error {
  border: 2rpx solid #ff4d4f;
}

.error-text {
  color: #ff4d4f;
  font-size: 24rpx;
  margin-top: 12rpx;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 选择器 */
.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.form-picker .placeholder {
  color: #999;
}

/* 开关 */
switch {
  margin-right: 16rpx;
}

.switch-label {
  font-size: 28rpx;
  color: #999;
}

.switch-label.active {
  color: #1890ff;
}

/* 信息展示 */
.info-item {
  display: flex;
  padding: 12rpx 0;
  font-size: 26rpx;
}

.info-label {
  color: #999;
  width: 140rpx;
}

.info-value {
  color: #333;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  border-radius: 44rpx;
  margin: 0 10rpx;
}

.btn-draft {
  background: #fff;
  color: #1890ff;
  border: 2rpx solid #1890ff;
}

.btn-publish {
  background: #1890ff;
  color: #fff;
}

/* 删除按钮 */
.delete-action {
  padding: 40rpx 30rpx;
}

.btn-delete {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #fff;
  color: #ff4d4f;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: 2rpx solid #ff4d4f;
}

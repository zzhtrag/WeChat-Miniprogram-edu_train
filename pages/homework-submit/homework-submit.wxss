/* Homework Submit Page */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* Loading */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx;
  color: #94A3B8;
  font-size: 28rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 32rpx;
  animation: fadeIn 400ms cubic-bezier(0.16, 1, 0.3, 1) both;
}

.empty-state-icon {
  width: 104rpx;
  height: 104rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-state-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0F172A;
  margin-bottom: 10rpx;
}

.empty-state-text {
  font-size: 26rpx;
  color: #94A3B8;
}

/* Detail Content */
.detail-content {
  padding: 24rpx 24rpx 180rpx;
}

/* Info Card */
.info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.info-card-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

.info-card-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: rgba(79, 70, 229, 0.08);
}

.info-card-text {
  flex: 1;
  min-width: 0;
}

.info-card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0F172A;
  line-height: 1.3;
  letter-spacing: -0.01em;
  display: block;
  margin-bottom: 8rpx;
}

.info-card-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.info-card-course {
  font-size: 22rpx;
  color: #4F46E5;
  background: rgba(79, 70, 229, 0.08);
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.info-card-teacher {
  font-size: 22rpx;
  color: #64748B;
  font-weight: 500;
}

.info-card-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.info-card-icon-text {
  font-size: 26rpx;
  margin-right: 8rpx;
}

.info-card-label {
  font-size: 26rpx;
  color: #64748B;
  font-weight: 500;
  margin-right: 12rpx;
}

.info-card-value {
  font-size: 26rpx;
  color: #0F172A;
  font-weight: 500;
}

.info-card-desc {
  background: #F8FAFC;
  border-radius: 12rpx;
  padding: 20rpx;
}

.info-card-desc-label {
  font-size: 24rpx;
  color: #94A3B8;
  font-weight: 600;
  margin-bottom: 8rpx;
  display: block;
}

.info-card-desc-content {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.6;
  display: block;
}

/* Section Card */
.section-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.section-icon-emoji {
  font-size: 28rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0F172A;
  letter-spacing: -0.01em;
}

.section-subtitle {
  font-size: 24rpx;
  color: #94A3B8;
  margin-left: 8rpx;
  font-weight: 400;
}

/* Content Input */
.content-input {
  width: 100%;
  min-height: 240rpx;
  font-size: 28rpx;
  color: #0F172A;
  line-height: 1.7;
  padding: 24rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
  border: 2rpx solid #E2E8F0;
  box-sizing: border-box;
  transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
}

.content-input:focus {
  border-color: #4F46E5;
  box-shadow: 0 0 0 4rpx rgba(79, 70, 229, 0.08);
}

.input-counter {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.counter-text {
  font-size: 24rpx;
  color: #CBD5E1;
  font-weight: 500;
}

/* Image Upload */
.image-upload-area {
  margin-top: 4rpx;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.upload-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: #F1F5F9;
}

.image-remove {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #DC2626;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(220, 38, 38, 0.3);
  z-index: 2;
}

.remove-icon {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #CBD5E1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #FAFAFA;
  transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
}

.image-add:active {
  background: #F1F5F9;
  border-color: #4F46E5;
}

.add-icon {
  font-size: 56rpx;
  color: #CBD5E1;
  font-weight: 300;
  line-height: 1;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 22rpx;
  color: #94A3B8;
  font-weight: 500;
}

/* Bottom Action */
.bottom-action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.btn-submit-action {
  width: 100%;
  background: linear-gradient(135deg, #4F46E5 0%, #6366F1 100%);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 28rpx 0;
  box-shadow: 0 4rpx 16rpx -4rpx rgba(79, 70, 229, 0.3);
  transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
}

.btn-submit-action:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx -2rpx rgba(79, 70, 229, 0.2);
}

.btn-submit-action[disabled] {
  background: #CBD5E1;
  box-shadow: none;
  transform: none;
}

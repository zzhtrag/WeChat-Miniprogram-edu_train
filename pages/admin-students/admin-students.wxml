<view class="page-container">
  <view class="search-section">
    <view class="search-box">
      <input
        class="search-input"
        placeholder="搜索学生姓名、学号"
        value="{{keyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
      />
    </view>
    <view class="filter-btn" bindtap="showFilter">筛选</view>
  </view>

  <view class="toolbar-section">
    <view class="toolbar-btn export-btn" bindtap="onExportStudents">导出数据</view>
    <view class="toolbar-btn import-btn" bindtap="onImportStudents">导入数据</view>
  </view>

  <view class="stats-section">
    <view class="stats-card">
      <view class="stats-item">
        <view class="stats-number">{{stats.total}}</view>
        <view class="stats-label">学生总数</view>
      </view>
      <view class="stats-item">
        <view class="stats-number active">{{stats.active}}</view>
        <view class="stats-label">在读</view>
      </view>
      <view class="stats-item">
        <view class="stats-number inactive">{{stats.inactive}}</view>
        <view class="stats-label">离校</view>
      </view>
    </view>
  </view>

  <view class="student-list" wx:if="{{studentList.length > 0}}">
    <view class="student-card" wx:for="{{studentList}}" wx:key="id" bindtap="viewStudent" data-id="{{item.id}}">
      <view class="student-main interactive-item interactive-admin">
        <view class="student-header">
          <view class="student-avatar">{{item.name ? item.name.charAt(0) : 'S'}}</view>
          <view class="student-info">
            <view class="student-name-row">
              <view class="student-name">{{item.name}}</view>
              <view class="student-status {{item.status}}">{{item.status === 'active' ? '在读' : '离校'}}</view>
            </view>
            <view class="student-no">学号：{{item.studentNo}}</view>
            <view class="student-tags" wx:if="{{item.tags && item.tags.length > 0}}">
              <view class="tag" wx:for="{{item.tags}}" wx:key="index">{{item}}</view>
            </view>
          </view>
        </view>
        <view class="student-footer">
          <view class="footer-item">
            <view class="footer-icon-wrapper">📚</view>
            <view class="footer-text">{{item.classCount}}门课程</view>
          </view>
          <view class="footer-item">
            <view class="footer-icon-wrapper">📍</view>
            <view class="footer-text">{{item.address}}</view>
          </view>
        </view>
      </view>
      <view class="student-actions" catchtap="noop">
        <view class="action-btn" bindtap="editStudent" data-id="{{item.id}}">编辑</view>
        <view class="action-btn delete" bindtap="deleteStudent" data-id="{{item.id}}">删除</view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{studentList.length === 0}}">
    <view class="empty-icon">👦</view>
    <view class="empty-title">暂无学生</view>
    <view class="empty-text">点击下方按钮添加学生</view>
  </view>

  <view class="add-btn" bindtap="addStudent">
    <view class="add-icon">+</view>
    <view class="add-text">添加学生</view>
  </view>

  <!-- 导出字段选择弹窗 -->
  <view class="sheet-mask" wx:if="{{showExportModal}}" bindtap="hideExportModal">
    <view class="sheet-container" catchtap="">
      <view class="sheet-header">
        <view class="sheet-title">选择导出字段</view>
        <view class="sheet-close" bindtap="hideExportModal">✕</view>
      </view>
      <view class="select-all-row" bindtap="toggleExportSelectAll">
        <view class="checkbox {{exportSelectAll ? 'checked' : ''}}">
          <view class="checkbox-inner" wx:if="{{exportSelectAll}}"></view>
        </view>
        <view class="select-all-text">全选</view>
      </view>
      <scroll-view class="field-scroll" scroll-y>
        <view class="field-item" wx:for="{{exportFields}}" wx:key="key" bindtap="toggleExportField" data-index="{{index}}">
          <view class="checkbox {{item.selected ? 'checked' : ''}}">
            <view class="checkbox-inner" wx:if="{{item.selected}}"></view>
          </view>
          <view class="field-label">{{item.label}}</view>
          <view class="field-required" wx:if="{{item.required}}">必选</view>
        </view>
      </scroll-view>
      <view class="sheet-footer">
        <view class="sheet-btn sheet-btn-cancel" bindtap="hideExportModal">取消</view>
        <view class="sheet-btn sheet-btn-primary" bindtap="confirmExport">确认导出</view>
      </view>
    </view>
  </view>

  <!-- 导入操作面板 -->
  <view class="sheet-mask" wx:if="{{showImportAction}}" bindtap="hideImportAction">
    <view class="sheet-container sheet-container-small" catchtap="">
      <view class="sheet-header">
        <view class="sheet-title">导入学生数据</view>
        <view class="sheet-close" bindtap="hideImportAction">✕</view>
      </view>
      <view class="action-card" bindtap="onDownloadTemplate">
        <view class="action-card-icon action-card-icon-green">T</view>
        <view class="action-card-content">
          <view class="action-card-title">下载导入模板</view>
          <view class="action-card-desc">下载CSV模板文件，按格式填写后导入</view>
        </view>
      </view>
      <view class="action-card" bindtap="onChooseImportFile">
        <view class="action-card-icon action-card-icon-blue">F</view>
        <view class="action-card-content">
          <view class="action-card-title">选择文件导入</view>
          <view class="action-card-desc">选择已填写好的CSV文件进行批量导入</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 导入预览弹窗 -->
  <view class="import-modal-mask" wx:if="{{showImportModal}}" bindtap="hideImportModal">
    <view class="import-modal" catchtap="">
      <view class="import-modal-header">
        <view class="import-modal-title">导入预览</view>
        <view class="import-modal-close" bindtap="hideImportModal">✕</view>
      </view>
      <view class="import-modal-info">共 {{importData.length}} 条数据，以下为前 {{importPreview.length}} 条预览</view>
      <scroll-view class="import-modal-list" scroll-y>
        <view class="import-preview-item" wx:for="{{importPreview}}" wx:key="index">
          <view class="import-preview-name">{{item.name}}</view>
          <view class="import-preview-detail">
            <text wx:if="{{item.student_no}}">学号：{{item.student_no}}</text>
            <text wx:if="{{item.grade}}"> · {{item.grade}}</text>
            <text wx:if="{{item.gender}}"> · {{item.gender}}</text>
          </view>
        </view>
      </scroll-view>
      <view class="import-modal-actions">
        <view class="import-modal-btn cancel-btn" bindtap="hideImportModal">取消</view>
        <view class="import-modal-btn confirm-btn" bindtap="confirmImport">确认导入</view>
      </view>
    </view>
  </view>
</view>

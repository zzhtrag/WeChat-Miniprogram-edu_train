.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  font-size: 28rpx;
  color: #999;
}

.info-card {
  background: #ffffff;
  margin: 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.class-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.class-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.status-tag {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.status-tag.active {
  background: #e6f7e6;
  color: #52c41a;
}

.status-tag.inactive, .status-tag.ended {
  background: #f5f5f5;
  color: #999;
}

.detail-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.detail-item {
  display: flex;
  flex-direction: column;
}

.detail-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.detail-value {
  font-size: 28rpx;
  color: #333;
}

.section {
  margin: 0 30rpx 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

.student-list, .schedule-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.student-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  border-left: 4rpx solid rgba(5, 150, 105, 0.25);
  transition: all 250ms ease;
}

.student-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1677ff, #69b1ff);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.student-info {
  flex: 1;
}

.student-name {
  font-size: 30rpx;
  color: #333;
  display: block;
}

.student-no {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.arrow {
  font-size: 32rpx;
  color: #ccc;
}

.student-item:active {
  border-left-color: #059669;
  background: rgba(5, 150, 105, 0.03);
  transform: scale(0.98);
}

.schedule-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  border-left: none;
}

.schedule-date {
  font-size: 28rpx;
  color: #333;
  width: 180rpx;
}

.schedule-time {
  flex: 1;
  font-size: 26rpx;
  color: #666;
}

.schedule-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.schedule-status.scheduled {
  background: #e6f7ff;
  color: #1677ff;
}

.schedule-status.completed {
  background: #e6f7e6;
  color: #52c41a;
}

.schedule-status.cancelled {
  background: #fff1f0;
  color: #ff4d4f;
}

.empty-tips {
  text-align: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: #999;
}

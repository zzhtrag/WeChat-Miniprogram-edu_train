.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* Student header */
.student-header {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 30rpx;
  margin: 30rpx;
  border-radius: 16rpx;
}

.student-avatar-placeholder {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1677ff, #69b1ff);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.avatar-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: 700;
}

.student-info {
  flex: 1;
}

.student-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f1f1f;
  margin-bottom: 8rpx;
}

.student-no {
  font-size: 24rpx;
  color: #999;
}

/* Info card */
.info-card {
  background: #fff;
  margin: 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.assignment-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.assignment-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f1f1f;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 20rpx;
}

.content-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.no-content {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
}

/* Image section */
.image-section {
  margin-top: 20rpx;
}

.image-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.submit-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

/* Submit time */
.submit-time-row {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f0f0f0;
}

.time-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 20rpx;
}

.time-value {
  font-size: 24rpx;
  color: #333;
}

/* No submission */
.no-submission {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
}

.no-submission-text {
  font-size: 28rpx;
  color: #999;
}

/* Grading form */
.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
}

.form-textarea {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  min-height: 200rpx;
  width: 100%;
  box-sizing: border-box;
  color: #333;
}

/* Bottom action */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.grade-btn {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
  color: #fff;
  text-align: center;
  padding: 28rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
}

/* Empty state */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 200rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

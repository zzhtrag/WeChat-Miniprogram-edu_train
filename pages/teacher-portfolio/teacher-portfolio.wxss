.page-container {
  min-height: 100vh;
  background: #F8FAFC;
  padding-bottom: 140rpx;
}

/* 班级选择 */
.class-selector {
  padding: 20rpx 24rpx;
  background: #FFFFFF;
}

.class-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.class-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
}

.picker-arrow {
  font-size: 28rpx;
  color: #6B7280;
}

/* 统计 */
.stats-row {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx;
}

.stat-chip {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  flex: 1;
  justify-content: center;
  border: 1px solid rgba(226, 232, 240, 0.5);
}

.stat-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #059669;
}

.stat-chip.excellent .stat-num { color: #F59E0B; }
.stat-chip.featured .stat-num { color: #8B5CF6; }

.stat-text {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 视图切换 */
.view-tabs {
  display: flex;
  padding: 16rpx 24rpx;
  gap: 12rpx;
}

.view-tab {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #6B7280;
  background: #FFFFFF;
  border: 1px solid #E5E7EB;
}

.view-tab.active {
  background: linear-gradient(135deg, #059669, #10B981);
  color: #FFFFFF;
  border-color: transparent;
  font-weight: 500;
}

/* 学生列表 */
.student-list {
  padding: 0 24rpx;
}

.student-group {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  border: 1px solid rgba(226, 232, 240, 0.5);
}

.student-header {
  display: flex;
  align-items: center;
  padding: 24rpx;
  gap: 16rpx;
}

.student-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.student-summary {
  flex: 1;
}

.student-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  display: block;
}

.student-stats {
  display: flex;
  gap: 16rpx;
  margin-top: 4rpx;
}

.s-stat {
  font-size: 24rpx;
  color: #9CA3AF;
}

.s-stat.excellent {
  color: #F59E0B;
}

.expand-arrow {
  font-size: 36rpx;
  color: #D1D5DB;
  transition: transform 200ms;
}

.expand-arrow.expanded {
  transform: rotate(90deg);
}

.student-portfolio {
  padding: 0 24rpx 24rpx;
  border-top: 1px solid #F3F4F6;
}

.portfolio-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding-top: 16rpx;
}

.portfolio-thumb {
  width: calc(33.33% - 8rpx);
  position: relative;
}

.thumb-img {
  width: 100%;
  height: 180rpx;
  border-radius: 12rpx;
}

.thumb-placeholder {
  width: 100%;
  height: 180rpx;
  border-radius: 12rpx;
  background: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
}

.thumb-icon {
  font-size: 40rpx;
}

.thumb-badges {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  display: flex;
  gap: 4rpx;
}

.badge {
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.badge.excellent {
  background: #FEF3C7;
  color: #D97706;
}

.badge.featured {
  background: #EDE9FE;
  color: #7C3AED;
}

.thumb-title {
  font-size: 22rpx;
  color: #374151;
  display: block;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 时间线 */
.timeline {
  padding: 0 24rpx;
}

.timeline-group {
  margin-bottom: 24rpx;
}

.timeline-month {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 16rpx;
  display: block;
}

.timeline-items {
  padding-left: 24rpx;
  border-left: 3px solid #E5E7EB;
}

.timeline-item {
  position: relative;
  margin-bottom: 16rpx;
  padding-left: 24rpx;
}

.timeline-dot {
  position: absolute;
  left: -29rpx;
  top: 28rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #10B981;
  border: 3px solid #FFFFFF;
}

.timeline-card {
  display: flex;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 16rpx;
  gap: 16rpx;
  border: 1px solid rgba(226, 232, 240, 0.5);
}

.card-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
  display: block;
  margin-bottom: 6rpx;
}

.card-meta {
  font-size: 24rpx;
  color: #9CA3AF;
  display: block;
  margin-bottom: 8rpx;
}

.card-badges {
  display: flex;
  gap: 8rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  opacity: 0.4;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 30rpx;
  color: #6B7280;
  display: block;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 浮动操作按钮 */
.fab-container {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  z-index: 50;
}

.fab-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #059669, #10B981);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 16px rgba(5, 150, 105, 0.4);
}

.fab-btn:active {
  transform: scale(0.92);
}

.fab-icon {
  font-size: 48rpx;
  color: #FFFFFF;
  font-weight: 300;
}

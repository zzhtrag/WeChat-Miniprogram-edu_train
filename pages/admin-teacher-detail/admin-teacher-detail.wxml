<view class="container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-view">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 教师详情 -->
  <block wx:else>
    <!-- 基本信息卡片 -->
    <view class="info-card">
      <view class="card-header">
        <view class="header-left">
          <image class="avatar" src="{{teacher.avatar}}" mode="aspectFill" />
          <view class="header-info">
            <view class="name-row">
              <text class="name">{{teacher.name}}</text>
              <view class="status-tag {{teacher.status === 'active' ? 'active' : 'inactive'}}">
                {{teacher.status === 'active' ? '在职' : '禁用'}}
              </view>
            </view>
            <text class="employee-no">工号：{{teacher.employee_no}}</text>
          </view>
        </view>
        <view class="header-actions">
          <view class="action-btn" bindtap="callTeacher">
            <text class="action-icon">📞</text>
          </view>
          <view class="action-btn" bindtap="showMoreActions">
            <text class="action-icon">⋮</text>
          </view>
        </view>
      </view>

      <!-- 统计数据 -->
      <view class="stats-row">
        <view class="stat-item">
          <text class="stat-value">{{teacher.class_count || 0}}</text>
          <text class="stat-label">管理班级</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{teacher.student_count || 0}}</text>
          <text class="stat-label">负责学生</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{teacher.subjects.length || 0}}</text>
          <text class="stat-label">教授科目</text>
        </view>
      </view>
    </view>

    <!-- 详细信息 -->
    <view class="detail-section">
      <view class="section-title">基本信息</view>
      <view class="detail-card">
        <view class="detail-row">
          <text class="detail-label">手机号码</text>
          <text class="detail-value">{{teacher.phone || '未设置'}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">电子邮箱</text>
          <text class="detail-value">{{teacher.email || '未设置'}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">入职日期</text>
          <text class="detail-value">{{teacher.entry_date || '未设置'}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">学历</text>
          <text class="detail-value">{{teacher.education || '未设置'}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">毕业院校</text>
          <text class="detail-value">{{teacher.school || '未设置'}}</text>
        </view>
      </view>
    </view>

    <!-- 科目信息 -->
    <view class="detail-section">
      <view class="section-title">教授科目</view>
      <view class="detail-card">
        <view class="tags-container" wx:if="{{teacher.subjects.length > 0}}">
          <view class="tag" wx:for="{{teacher.subjects}}" wx:key="index">{{item}}</view>
        </view>
        <text class="empty-text" wx:else>暂无科目</text>
      </view>
    </view>

    <!-- 负责班级 -->
    <view class="detail-section">
      <view class="section-title">负责班级</view>
      <view class="classes-list" wx:if="{{teacherClasses.length > 0}}">
        <view class="class-item interactive-item interactive-admin" wx:for="{{teacherClasses}}" wx:key="id" data-id="{{item.id}}" bindtap="viewClassDetail">
          <view class="class-info">
            <text class="class-name">{{item.name}}</text>
            <text class="class-course">{{item.course_name}}</text>
          </view>
          <view class="class-meta">
            <text class="student-count">{{item.student_count}}名学员</text>
            <text class="interactive-arrow">›</text>
          </view>
        </view>
      </view>
      <view class="empty-card" wx:else>
        <text class="empty-text">暂无负责的班级</text>
      </view>
    </view>
  </block>
</view>

<view class="container">
  <view class="profile-header">
    <image class="avatar" src="{{teacherInfo.avatar || '/images/default-avatar.png'}}" mode="aspectFill"/>
    <view class="name">{{teacherInfo.name}}</view>
    <view class="title">{{teacherInfo.subjectsDisplay}} · 工号 {{teacherInfo.employee_no}}</view>
  </view>

  <view class="info-section">
    <view class="section-title">基本信息</view>
    <view class="info-list">
      <view class="info-item">
        <view class="info-label">姓名</view>
        <view class="info-value">{{teacherInfo.name}}</view>
      </view>
      <view class="info-item">
        <view class="info-label">工号</view>
        <view class="info-value">{{teacherInfo.employee_no}}</view>
      </view>
      <view class="info-item">
        <view class="info-label">手机号</view>
        <view class="info-value">{{teacherInfo.phone}}</view>
      </view>
      <view class="info-item">
        <view class="info-label">入职日期</view>
        <view class="info-value">{{teacherInfo.entry_date}}</view>
      </view>
    </view>
  </view>

  <view class="info-section">
    <view class="section-title">教学信息</view>
    <view class="info-list">
      <view class="info-item">
        <view class="info-label">教授科目</view>
        <view class="info-value">{{teacherInfo.subjectsDisplay}}</view>
      </view>
      <view class="info-item">
        <view class="info-label">任教班级</view>
        <view class="info-value">{{classCount}}个班级</view>
      </view>
      <view class="info-item">
        <view class="info-label">学员总数</view>
        <view class="info-value">{{studentCount}}人</view>
      </view>
    </view>
  </view>

  <view class="info-section">
    <view class="section-title">账户信息</view>
    <view class="info-list">
      <view class="info-item">
        <view class="info-label">账号状态</view>
        <view class="info-value status-active">{{teacherInfo.status === 'active' ? '正常' : '禁用'}}</view>
      </view>
    </view>
  </view>

  <view class="action-section">
    <view class="action-btn" bindtap="editProfile">编辑资料</view>
    <view class="action-btn outline" bindtap="changePassword">修改密码</view>
  </view>
</view>

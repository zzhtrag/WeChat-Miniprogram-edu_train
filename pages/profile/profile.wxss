.container {
  padding: 0;
  background: #f5f5f5;
  min-height: 100vh;
}

.header-section {
  background: linear-gradient(135deg, #1677ff 0%, #0958d9 100%);
  padding: 40rpx 30rpx 60rpx;
}

.user-card {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.user-class {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.role-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.role-tag.student {
  background: rgba(255, 255, 255, 0.3);
  color: #ffffff;
}

.role-tag.teacher {
  background: #faad14;
  color: #ffffff;
}

.edit-btn {
  padding: 10rpx;
}

.edit-icon {
  font-size: 32rpx;
}

.stats-card {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 40rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  backdrop-filter: blur(10rpx);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.2);
}

.menu-section {
  margin-top: -30rpx;
  padding: 0 20rpx;
}

.menu-group {
  background: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  position: relative;
}

.menu-item:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 80rpx;
  right: 0;
  bottom: 0;
  height: 2rpx;
  background: #f0f0f0;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  width: 56rpx;
  text-align: center;
}

.menu-title {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.menu-badge {
  background: #ff4d4f;
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-right: 10rpx;
  min-width: 32rpx;
  text-align: center;
}

.menu-arrow {
  font-size: 32rpx;
  color: #999999;
}

.logout-section {
  padding: 40rpx 20rpx;
}

.logout-btn {
  width: 100%;
  background: #ffffff;
  color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
  border-radius: 48rpx;
  padding: 28rpx;
  font-size: 30rpx;
  font-weight: 500;
}

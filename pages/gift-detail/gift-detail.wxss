.container {
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.loading-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
}

.gift-image-section {
  position: relative;
  width: 100%;
  height: 500rpx;
}

.gift-big-image {
  width: 100%;
  height: 100%;
  background: #e5e7eb;
}

.stock-badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  background: rgba(217, 119, 6, 0.9);
  color: #ffffff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.gift-info-section {
  background: #ffffff;
  padding: 30rpx;
  margin-bottom: 16rpx;
}

.gift-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.gift-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
}

.gift-points {
  font-size: 32rpx;
  font-weight: 700;
  color: #D97706;
}

.gift-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

.points-section {
  background: #ffffff;
  padding: 30rpx;
  margin-bottom: 16rpx;
}

.points-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.points-label {
  font-size: 28rpx;
  color: #666666;
}

.points-balance {
  font-size: 36rpx;
  font-weight: 700;
  color: #4F46E5;
}

.points-hint {
  font-size: 24rpx;
  color: #DC2626;
  margin-top: 8rpx;
}

.exchange-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.exchange-btn {
  background: #4F46E5;
  color: #ffffff;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.exchange-btn.disabled {
  background: #e5e7eb;
  color: #9ca3af;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.modal-content {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #ffffff;
  border-radius: 30rpx 30rpx 0 0;
  padding: 30rpx;
  z-index: 101;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  font-size: 28rpx;
  color: #999999;
  padding: 8rpx;
}

.modal-gift-info {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.modal-gift-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 4rpx;
}

.modal-gift-cost {
  font-size: 24rpx;
  color: #D97706;
}

.form-group {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 26rpx;
  color: #333333;
  margin-bottom: 8rpx;
  display: block;
}

.required { color: #ff4d4f; }

.form-input {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-textarea {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  height: 120rpx;
}

.error-text {
  font-size: 22rpx;
  color: #ff4d4f;
  margin-top: 6rpx;
}

.modal-action { margin-top: 20rpx; }

.confirm-btn {
  background: #4F46E5;
  color: #ffffff;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.confirm-btn.disabled {
  opacity: 0.6;
}

/* pages/teacher-timetable/teacher-timetable.wxss */

/* 容器 */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 300rpx;
  color: #999;
  font-size: 28rpx;
}

/* 日历区域 */
.calendar-section {
  background: #fff;
  padding: 24rpx 20rpx 16rpx;
}

/* 月份导航 */
.month-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-bottom: 20rpx;
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
}

.nav-btn:active {
  background: #e6e6e6;
}

.nav-arrow {
  font-size: 40rpx;
  color: #22C55E;
  line-height: 1;
}

.month-info {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.month-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.expand-arrow {
  font-size: 22rpx;
  color: #22C55E;
  transition: transform 300ms ease;
}

.expand-arrow.expanded {
  transform: rotate(180deg);
}

/* 星期标题 */
.week-header {
  display: flex;
  padding: 0 4rpx;
  margin-bottom: 8rpx;
}

.week-day {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}

/* 月历网格 - 展开 */
.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  transition: max-height 300ms ease;
}

.calendar-grid.expanded {
  max-height: 800rpx;
  overflow: hidden;
}

.calendar-grid.collapsed {
  max-height: 0;
  overflow: hidden;
}

.day-cell {
  width: 14.28%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 0;
  position: relative;
}

.day-cell .day-num {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  border-radius: 14rpx;
  transition: all 200ms ease;
}

.day-cell.other-month .day-num {
  color: #ccc;
}

.day-cell.today .day-num {
  background: rgba(34, 197, 94, 0.1);
  color: #22C55E;
  font-weight: 700;
}

.day-cell.selected .day-num {
  background: #22C55E;
  color: #fff;
  font-weight: 700;
  box-shadow: 0 2px 8px rgba(34, 197, 94, 0.3);
}

.day-cell .course-dot {
  width: 8rpx;
  height: 8rpx;
  background: #EF4444;
  border-radius: 50%;
  margin-top: 4rpx;
}

.day-cell.selected .course-dot {
  background: #fff;
}

/* 周日历 - 收起 */
.week-days {
  display: flex;
  padding: 8rpx 0 0;
}

.day-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
  margin: 0 4rpx;
  border-radius: 12rpx;
  position: relative;
  transition: all 0.3s;
}

.day-item.active {
  background: #22C55E;
}

.day-item.today:not(.active) {
  background: rgba(34, 197, 94, 0.08);
}

.day-week {
  font-size: 22rpx;
  color: #999;
}

.day-item.active .day-week {
  color: #fff;
}

.day-item .day-num {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-top: 4rpx;
}

.day-item.active .day-num {
  color: #fff;
}

.course-dot-week {
  width: 8rpx;
  height: 8rpx;
  background: #EF4444;
  border-radius: 50%;
  margin-top: 4rpx;
}

.day-item.active .course-dot-week {
  background: #fff;
}

/* 课程内容 */
.schedule-content {
  padding: 20rpx 30rpx;
}

/* 日期头部 */
.date-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.date-text {
  font-size: 28rpx;
  color: #666;
}

.today-tag {
  margin-left: 16rpx;
  padding: 4rpx 16rpx;
  background: #22C55E;
  color: #fff;
  font-size: 22rpx;
  border-radius: 20rpx;
}

.tomorrow-tag {
  margin-left: 16rpx;
  padding: 4rpx 16rpx;
  background: #1890ff;
  color: #fff;
  font-size: 22rpx;
  border-radius: 20rpx;
}

.day-section {
  margin-bottom: 24rpx;
}

.day-section:last-child {
  margin-bottom: 0;
}

/* 空状态 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  background: #fff;
  border-radius: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 20rpx;
}

/* 课程卡片 */
.schedule-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  position: relative;
  overflow: hidden;
}

.schedule-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: #22C55E;
}

.schedule-card.upcoming::before { background: #faad14; }
.schedule-card.ongoing::before { background: #52c41a; }
.schedule-card.completed::before { background: #999; }
.schedule-card.cancelled::before { background: #ff4d4f; }
.schedule-card.cancelled { opacity: 0.6; }

/* 时间区域 */
.time-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 24rpx;
  padding-right: 24rpx;
  border-right: 1px solid #f0f0f0;
}

.time-start, .time-end {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.time-line {
  flex: 1;
  width: 2rpx;
  background: #ddd;
  margin: 8rpx 0;
}

/* 课程区域 */
.course-section {
  flex: 1;
}

.course-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.course-info {
  display: flex;
  flex-wrap: wrap;
}

.info-row {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
  margin-bottom: 8rpx;
}

.icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.info-row text {
  font-size: 24rpx;
  color: #666;
}

/* 状态区域 */
.status-section {
  display: flex;
  align-items: flex-start;
}

.status-tag {
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  border-radius: 6rpx;
}

.status-tag.upcoming {
  background: #fff7e6;
  color: #fa8c16;
}

.status-tag.ongoing {
  background: #f6ffed;
  color: #52c41a;
}

.status-tag.completed {
  background: #f5f5f5;
  color: #999;
}

.status-tag.cancelled {
  background: #fff1f0;
  color: #ff4d4f;
}

/* 本周概览 */
.week-summary {
  margin: 20rpx 30rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.summary-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1px solid #f0f0f0;
}

.summary-list {
  display: flex;
  justify-content: space-around;
}

.summary-item {
  text-align: center;
}

.summary-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #22C55E;
}

.summary-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

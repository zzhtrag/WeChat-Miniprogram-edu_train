.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.header-actions {
  padding: 20rpx;
  background: #ffffff;
}

.publish-btn {
  background: linear-gradient(135deg, #1677ff 0%, #0958d9 100%);
  color: #ffffff;
  border-radius: 40rpx;
  padding: 20rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}

.publish-btn .icon {
  font-size: 36rpx;
  margin-right: 8rpx;
  line-height: 1;
}

.tabs {
  display: flex;
  background: #ffffff;
  padding: 0 20rpx;
  margin-top: 20rpx;
  position: relative;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #1677ff;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #1677ff;
  border-radius: 2rpx;
}

.badge {
  position: absolute;
  top: 16rpx;
  right: 20rpx;
  background: #ff4d4f;
  color: #ffffff;
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
}

.tab-content {
  padding: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 20rpx;
}

.submission-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.submission-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.submission-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.student-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.student-info {
  flex: 1;
}

.student-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 6rpx;
}

.homework-title {
  font-size: 24rpx;
  color: #666666;
}

.submit-time {
  font-size: 22rpx;
  color: #999999;
}

.submission-content {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.6;
  margin-bottom: 20rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.submission-images {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.submission-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

.submission-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

.action-btn {
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
}

.action-btn.grade {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
  color: #ffffff;
}

.homework-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.homework-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  border-left: 4rpx solid rgba(5, 150, 105, 0.25);
  transition: all 250ms ease;
}

.homework-card:active {
  border-left-color: #059669;
  background: rgba(5, 150, 105, 0.03);
  transform: scale(0.98);
}

.homework-info {
  flex: 1;
}

.homework-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 10rpx;
}

.homework-class {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.homework-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #1677ff, #69b1ff);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #666666;
  white-space: nowrap;
}

.homework-stats {
  margin-left: 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 6rpx;
}

.stat-value.pending {
  color: #ff4d4f;
}

.stat-label {
  font-size: 22rpx;
  color: #999999;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.grade-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  z-index: 101;
  max-height: 80vh;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f1f1f;
}

.modal-close {
  font-size: 40rpx;
  color: #999999;
  line-height: 1;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  padding: 30rpx;
}

.student-info-row {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
}

.modal-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.modal-student-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 6rpx;
}

.modal-homework-title {
  font-size: 24rpx;
  color: #666666;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
}

.form-input {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.form-textarea {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  min-height: 200rpx;
  width: 100%;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 2rpx solid #f0f0f0;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 28rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666666;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
  color: #ffffff;
}

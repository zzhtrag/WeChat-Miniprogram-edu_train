/* pages/admin-stats/admin-stats.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #eef3ff 0%, #f5f5f5 20%);
  padding-bottom: 40rpx;
}

/* 标签导航 */
.tab-nav {
  display: flex;
  background: #fff;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #1890ff;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #1890ff;
  border-radius: 2rpx;
}

/* 标签内容 */
.tab-content {
  padding: 30rpx;
}

/* 区块 */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

/* 核心数据网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.stat-card {
  background: linear-gradient(135deg, #f8f9ff 0%, #f0f5ff 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
}

.stat-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.stat-label {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
}

.stat-sub {
  font-size: 22rpx;
  color: #52c41a;
  margin-top: 8rpx;
}

/* 业务数据行 */
.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #1890ff;
}

.stat-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 班级容量 */
.capacity-list {
  margin-top: -10rpx;
}

.capacity-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.capacity-item:last-child {
  border-bottom: none;
}

.capacity-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.capacity-name {
  font-size: 28rpx;
  color: #333;
}

.capacity-num {
  font-size: 26rpx;
  color: #999;
}

.capacity-bar {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.capacity-fill {
  height: 100%;
  background: linear-gradient(90deg, #1890ff, #52c41a);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.capacity-fill.warning {
  background: linear-gradient(90deg, #faad14, #ff4d4f);
}

/* 趋势图表 */
.trend-card {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.trend-card:last-child {
  margin-bottom: 0;
}

.trend-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.trend-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.trend-current {
  font-size: 32rpx;
  color: #1890ff;
  font-weight: bold;
}

.trend-chart {
  height: 200rpx;
}

.bar-group {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 180rpx;
  padding-top: 20rpx;
}

.bar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar {
  width: 40rpx;
  border-radius: 8rpx 8rpx 0 0;
  transition: height 0.3s;
}

.bar-students {
  background: linear-gradient(180deg, #1890ff, #096dd9);
}

.bar-teachers {
  background: linear-gradient(180deg, #52c41a, #389e0d);
}

.bar-classes {
  background: linear-gradient(180deg, #faad14, #d48806);
}

.bar-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 分布列表 */
.distribution-list {
  margin-top: -10rpx;
}

.distribution-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.distribution-item:last-child {
  border-bottom: none;
}

.dist-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.dist-name {
  font-size: 28rpx;
  color: #333;
}

.dist-value {
  font-size: 26rpx;
  color: #999;
}

.dist-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.dist-fill {
  height: 100%;
  background: linear-gradient(90deg, #1890ff, #52c41a);
  border-radius: 8rpx;
}

/* 年级网格 */
.grade-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.grade-card {
  background: linear-gradient(135deg, #f0f5ff 0%, #e6f7ff 100%);
  border-radius: 12rpx;
  padding: 30rpx 20rpx;
  text-align: center;
}

.grade-name {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.grade-count {
  font-size: 40rpx;
  font-weight: bold;
  color: #1890ff;
  margin: 8rpx 0;
}

.grade-label {
  font-size: 22rpx;
  color: #999;
}

/* 教师列表 */
.teacher-list {
  margin-top: -10rpx;
}

.teacher-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.teacher-item:last-child {
  border-bottom: none;
}

.teacher-info {
  flex: 1;
}

.teacher-name {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.teacher-meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.teacher-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 考勤页面 */
.attendance-overview {
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
}

.attendance-ring {
  width: 200rpx;
  height: 200rpx;
  background: conic-gradient(#52c41a 0deg 324deg, #f0f0f0 324deg 360deg);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ring-circle {
  width: 160rpx;
  height: 160rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.ring-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.ring-label {
  font-size: 24rpx;
  color: #999;
}

/* 考勤卡片 */
.attendance-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-top: 30rpx;
}

.attendance-card {
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
}

.attendance-card.normal {
  background: #f6ffed;
}

.attendance-card.late {
  background: #fffbe6;
}

.attendance-card.absent {
  background: #fff1f0;
}

.attendance-card.leave {
  background: #f0f5ff;
}

.card-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.card-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.card-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 4rpx;
}

.card-percent {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 提示卡片 */
.tips-card {
  display: flex;
  background: #e6f7ff;
  border-radius: 12rpx;
  padding: 24rpx;
}

.tips-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.tips-content {
  flex: 1;
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1890ff;
  display: block;
  margin-bottom: 8rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

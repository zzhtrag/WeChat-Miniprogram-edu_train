/* pages/teacher-schedule-edit/teacher-schedule-edit.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 60rpx;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 表单区块 */
.form-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 2rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.form-label.required::before {
  content: '*';
  color: #ff4d4f;
  margin-right: 8rpx;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.form-picker text.placeholder {
  color: #999;
}

.form-picker.error {
  border: 2rpx solid #ff4d4f;
}

.arrow {
  font-size: 20rpx;
  color: #999;
}

.course-tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #52c41a;
}

/* 时间选择 */
.time-section .form-label {
  margin-bottom: 20rpx;
}

.time-row {
  display: flex;
  align-items: center;
}

.time-picker {
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.time-picker text.placeholder {
  color: #999;
}

.time-picker.error {
  border: 2rpx solid #ff4d4f;
}

.time-separator {
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #999;
}

.duration-tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #1890ff;
}

/* 文本域 */
.form-textarea {
  min-height: 160rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 错误提示 */
.error-text {
  color: #ff4d4f;
  font-size: 24rpx;
  margin-top: 12rpx;
}

/* 按钮区域 */
.btn-area {
  padding: 30rpx;
}

.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  border-radius: 44rpx;
}

.btn-primary {
  background: #1890ff;
  color: #fff;
}

/* 删除区域 */
.delete-area {
  padding: 0 30rpx;
}

.btn-delete {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #fff;
  color: #ff4d4f;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: 2rpx solid #ff4d4f;
}

/* Batch Dates */
.batch-dates-info {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
}

.batch-dates-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.batch-count {
  font-size: 26rpx;
  color: #1890ff;
  font-weight: 600;
}

.batch-add-btn {
  font-size: 26rpx;
  color: #1890ff;
  font-weight: 500;
}

.batch-dates-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.batch-date-tag {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #333;
  border: 1px solid #e8e8e8;
}

.batch-tag-remove {
  margin-left: 8rpx;
  font-size: 24rpx;
  color: #999;
  padding: 0 4rpx;
}

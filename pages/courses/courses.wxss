.container {
  padding: 0;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 搜索栏 */
.search-bar {
  background: #ffffff;
  padding: 20rpx 30rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.filter-btn {
  font-size: 26rpx;
  color: #1677ff;
  padding-left: 16rpx;
  border-left: 2rpx solid #e8e8e8;
  margin-left: 16rpx;
}

/* 轮播图 */
.banner-section {
  padding: 20rpx 30rpx;
}

.banner-swiper {
  width: 100%;
  height: 300rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
}

/* 分类快捷入口 */
.category-section {
  background: #ffffff;
  padding: 30rpx 0;
  margin-bottom: 20rpx;
}

.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: flex;
  padding: 0 30rpx;
}

.category-item {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
  opacity: 0.6;
}

.category-item.active {
  opacity: 1;
}

.category-item.active .category-icon {
  transform: scale(1.1);
}

.category-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
  transition: transform 0.3s;
}

.category-name {
  font-size: 24rpx;
  color: #333333;
}

/* 科目筛选 */
.subject-section {
  background: #ffffff;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.subject-scroll {
  white-space: nowrap;
}

.subject-list {
  display: flex;
  padding: 0 30rpx;
  gap: 20rpx;
}

.subject-item {
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666666;
  background: #f5f5f5;
}

.subject-item.active {
  background: linear-gradient(135deg, #1677ff 0%, #0958d9 100%);
  color: #ffffff;
  font-weight: 500;
}

/* 排序 */
.sort-section {
  background: #ffffff;
  padding: 20rpx 30rpx;
  margin-bottom: 2rpx;
}

.sort-tabs {
  display: flex;
  gap: 40rpx;
}

.sort-tab {
  font-size: 28rpx;
  color: #666666;
  position: relative;
  padding: 10rpx 0;
}

.sort-tab.active {
  color: #1677ff;
  font-weight: 600;
}

.sort-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #1677ff;
  border-radius: 2rpx;
}

/* 课程类型 */
.type-section {
  background: #ffffff;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
}

.type-tabs {
  display: flex;
  gap: 20rpx;
}

.type-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #666666;
  border-radius: 40rpx;
  background: #f5f5f5;
}

.type-tab.active {
  background: linear-gradient(135deg, #1677ff 0%, #0958d9 100%);
  color: #ffffff;
  font-weight: 500;
}

/* 课程列表 */
.course-list {
  padding: 20rpx 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.course-card {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  display: flex;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.course-cover-wrapper {
  position: relative;
  flex-shrink: 0;
}

.course-cover {
  width: 240rpx;
  height: 180rpx;
  display: block;
}

.course-type-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #ffffff;
}

.course-type-tag.type-video {
  background: linear-gradient(135deg, #1677ff 0%, #0958d9 100%);
}

.course-type-tag.type-article {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
}

.course-type-tag.type-live {
  background: linear-gradient(135deg, #ff4d4f 0%, #cf1322 100%);
}

.course-free-tag {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #faad14 0%, #d48806 100%);
}

.course-info {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.course-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.course-teacher {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.teacher-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.teacher-name {
  font-size: 24rpx;
  color: #333333;
  margin-right: 12rpx;
}

.teacher-desc {
  font-size: 22rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.course-meta {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.student-count {
  font-size: 22rpx;
  color: #999999;
}

.course-rating {
  font-size: 22rpx;
  color: #faad14;
}

.course-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.course-price {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.course-price .free {
  font-size: 32rpx;
  font-weight: 700;
  color: #52c41a;
}

.course-price .price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff4d4f;
}

.course-price .original-price {
  font-size: 22rpx;
  color: #999999;
  text-decoration: line-through;
}

.go-detail {
  font-size: 24rpx;
  color: #1677ff;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

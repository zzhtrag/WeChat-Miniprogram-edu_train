<view class="page-container">
  <!-- 消息列表 -->
  <view class="message-list" wx:if="{{announcements.length > 0}}">
    <view class="message-card interactive-item interactive-primary {{item.isRead ? 'read' : 'unread'}}"
          wx:for="{{announcements}}"
          wx:key="id"
          bindtap="viewAnnouncement"
          data-id="{{item.id}}">
      <view class="card-header">
        <view class="card-left">
          <view class="pin-icon" wx:if="{{item.isPinned}}">置顶</view>
          <view class="type-tag {{item.type}}">{{item.type === 'system' ? '系统' : item.type === 'parent' ? '家长' : '教师'}}</view>
        </view>
        <view class="publish-time">{{item.publishTime}}</view>
      </view>
      <view class="message-title">{{item.title}}</view>
      <view class="message-content">{{item.content}}</view>
      <view class="message-footer">
        <text class="publisher">发布者：{{item.publisherName}}</text>
        <text class="read-status {{item.isRead ? 'read' : ''}}">{{item.isRead ? '已读' : '未读'}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <view class="empty-icon">💬</view>
    <view class="empty-title">暂无消息通知</view>
    <view class="empty-text">有新消息会及时通知您</view>
  </view>
</view>

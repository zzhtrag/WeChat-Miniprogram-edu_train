/* Enrollment Status Query - Soft UI Evolution */
.page-container {
  min-height: 100vh;
  background-color: #F8FAFC;
}

/* Header - matches app gradient */
.header {
  position: relative;
  padding: 100rpx 48rpx 60rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, #4F46E5 0%, #6366F1 50%, #818CF8 100%);
  border-radius: 0 0 48rpx 48rpx;
}

.header-bg::after {
  content: '';
  position: absolute;
  top: -40%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.header-content {
  position: relative;
  display: flex;
  flex-direction: column;
  animation: fadeInUp 500ms cubic-bezier(0.16, 1, 0.3, 1) both;
}

.logo-area {
  display: flex;
  align-items: center;
}

.logo-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.15);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.logo-image {
  width: 76rpx;
  height: 76rpx;
  flex-shrink: 0;
}

.logo-text {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 37rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: -0.03em;
  margin-bottom: 4rpx;
}

.header-desc {
  font-size: 25rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

/* ============================================
   SEARCH CARD
   ============================================ */
.search-card {
  margin: -24rpx 32rpx 0;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4px 16px -4px rgba(79, 70, 229, 0.1), 0 8px 24px -8px rgba(79, 70, 229, 0.06);
  border: 1px solid rgba(226, 232, 240, 0.6);
  position: relative;
  z-index: 2;
  animation: fadeInUp 500ms cubic-bezier(0.16, 1, 0.3, 1) 100ms both;
}

.search-row {
  display: flex;
  align-items: center;
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 96rpx;
  border: 2rpx solid #E2E8F0;
  transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
}

.search-row:focus-within {
  border-color: #4F46E5;
  background: #FFFFFF;
  box-shadow: 0 0 0 4rpx rgba(79, 70, 229, 0.08);
}

.search-prefix {
  font-size: 28rpx;
  font-weight: 600;
  color: #475569;
  margin-right: 16rpx;
}

.search-divider {
  width: 2rpx;
  height: 32rpx;
  background: #E2E8F0;
  margin-right: 20rpx;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #0F172A;
  height: 96rpx;
}

.search-btn {
  padding: 16rpx 28rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #4F46E5, #6366F1);
  margin-left: 16rpx;
  transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
}

.search-btn:active {
  transform: scale(0.96);
}

.search-btn-disabled {
  background: #E2E8F0;
  pointer-events: none;
}

.search-btn-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 600;
  white-space: nowrap;
}

.search-btn-disabled .search-btn-text { color: #94A3B8; }

/* ============================================
   RESULTS
   ============================================ */
.results {
  padding: 32rpx;
}

.result-title-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0F172A;
}

.result-count-badge {
  padding: 6rpx 16rpx;
  background: rgba(79, 70, 229, 0.08);
  border-radius: 999rpx;
}

.result-count-text {
  font-size: 22rpx;
  color: #4F46E5;
  font-weight: 600;
}

/* ============================================
   REG CARD - Enhanced with avatar
   ============================================ */
.reg-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2px 8px -2px rgba(79, 70, 229, 0.08), 0 4px 12px -4px rgba(79, 70, 229, 0.04);
  border: 1px solid rgba(226, 232, 240, 0.5);
  animation: fadeInUp 400ms cubic-bezier(0.16, 1, 0.3, 1) both;
}

.reg-card:nth-child(2) { animation-delay: 60ms; }
.reg-card:nth-child(3) { animation-delay: 120ms; }

.reg-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.reg-code-area {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.reg-code-badge {
  padding: 8rpx 16rpx;
  background: rgba(79, 70, 229, 0.08);
  border-radius: 12rpx;
}

.reg-code-text {
  font-size: 26rpx;
  color: #4F46E5;
  font-weight: 700;
  letter-spacing: 0.1em;
}

.reg-subject-tag {
  font-size: 22rpx;
  color: #64748B;
  font-weight: 500;
  padding: 4rpx 12rpx;
  background: #F8FAFC;
  border-radius: 8rpx;
}

/* Status badge with dot indicator (accessible: not color-only) */
.status-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.status-enrolled { background: rgba(245, 158, 11, 0.1); }
.status-paid { background: rgba(59, 130, 246, 0.1); }
.status-admitted { background: rgba(16, 185, 129, 0.1); }

.status-enrolled .status-dot { background: #F59E0B; }
.status-paid .status-dot { background: #3B82F6; }
.status-admitted .status-dot { background: #10B981; }

.status-badge-text {
  font-size: 22rpx;
  font-weight: 600;
}

.status-enrolled .status-badge-text { color: #D97706; }
.status-paid .status-badge-text { color: #2563EB; }
.status-admitted .status-badge-text { color: #059669; }

/* Student avatar */
.reg-body {
  margin-bottom: 20rpx;
}

.student-row {
  display: flex;
  align-items: center;
}

.student-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.avatar-male { background: rgba(59, 130, 246, 0.1); }
.avatar-female { background: rgba(236, 72, 153, 0.1); }

.avatar-letter {
  font-size: 26rpx;
  font-weight: 700;
}

.avatar-male .avatar-letter { color: #3B82F6; }
.avatar-female .avatar-letter { color: #EC4899; }

.student-info {
  flex: 1;
}

.student-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #0F172A;
  display: block;
  margin-bottom: 4rpx;
}

.student-meta {
  font-size: 22rpx;
  color: #94A3B8;
}

/* Detail rows */
.reg-details {
  padding: 16rpx 0;
  border-top: 1px solid #F1F5F9;
  margin-bottom: 16rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}

.detail-label {
  font-size: 24rpx;
  color: #94A3B8;
  font-weight: 500;
}

.detail-value {
  font-size: 26rpx;
  color: #0F172A;
  font-weight: 500;
}

.detail-value.highlight {
  color: #4F46E5;
  font-weight: 600;
}

.detail-value.valid { color: #059669; }
.detail-value.expired { color: #EF4444; }

/* ============================================
   FLOW BAR - Enhanced dots
   ============================================ */
.flow-bar {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0 4rpx;
}

.flow-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  width: 80rpx;
}

.flow-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #F1F5F9;
  border: 3rpx solid #E2E8F0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  transition: all 300ms ease;
}

.flow-dot-inner {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: transparent;
  transition: all 300ms ease;
}

.flow-step.active .flow-dot {
  background: #4F46E5;
  border-color: #4F46E5;
  box-shadow: 0 0 0 5rpx rgba(79, 70, 229, 0.12);
}

.flow-step.active .flow-dot-inner {
  background: #FFFFFF;
}

.flow-label {
  font-size: 20rpx;
  color: #CBD5E1;
  font-weight: 500;
}

.flow-step.active .flow-label {
  color: #4F46E5;
  font-weight: 700;
}

.flow-line {
  flex: 1;
  height: 6rpx;
  background: #E2E8F0;
  margin: 15rpx 6rpx 0;
  border-radius: 3rpx;
  transition: background 300ms ease;
}

.flow-line.active {
  background: #4F46E5;
}

/* ============================================
   EMPTY STATE - No emoji, styled illustration
   ============================================ */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  animation: fadeInUp 400ms cubic-bezier(0.16, 1, 0.3, 1) both;
}

.empty-icon-wrapper {
  margin-bottom: 24rpx;
}

.empty-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #F1F5F9;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #E2E8F0;
}

.empty-q {
  font-size: 44rpx;
  font-weight: 700;
  color: #CBD5E1;
}

.empty-text {
  font-size: 28rpx;
  color: #64748B;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #94A3B8;
  margin-bottom: 32rpx;
}

.empty-action {
  padding: 16rpx 40rpx;
  background: rgba(79, 70, 229, 0.08);
  border-radius: 999rpx;
  transition: all 200ms ease;
}

.empty-action:active {
  transform: scale(0.96);
  background: rgba(79, 70, 229, 0.14);
}

.empty-action-text {
  font-size: 26rpx;
  color: #4F46E5;
  font-weight: 600;
}

/* ============================================
   ANIMATIONS
   ============================================ */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

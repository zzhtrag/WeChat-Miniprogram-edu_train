.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.points-banner {
  background: linear-gradient(135deg, #4F46E5, #7C3AED);
  border-radius: 20rpx;
  padding: 36rpx 30rpx;
  margin-bottom: 30rpx;
  color: #ffffff;
}

.points-content {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.points-label {
  font-size: 26rpx;
  opacity: 0.9;
  margin-right: 16rpx;
}

.points-value {
  font-size: 56rpx;
  font-weight: 700;
}

.points-hint {
  font-size: 22rpx;
  opacity: 0.75;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.gift-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.gift-card {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
}

.gift-image {
  width: 100%;
  height: 240rpx;
  background: #f5f5f5;
}

.gift-card-info {
  padding: 16rpx 20rpx 20rpx;
}

.gift-card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.gift-card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.gift-card-points {
  font-size: 24rpx;
  color: #D97706;
  font-weight: 600;
}

.exchange-btn {
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  background: #4F46E5;
  color: #ffffff;
}

.exchange-btn.disabled {
  background: #e5e7eb;
  color: #9ca3af;
}

.stock-tag {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: rgba(217, 119, 6, 0.9);
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.sold-out-tag {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: #999999; margin-top: 20rpx; }

.my-exchanges-entry {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 30rpx;
}

.entry-text {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.entry-arrow {
  font-size: 28rpx;
  color: #999999;
}

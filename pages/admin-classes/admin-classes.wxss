.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 搜索栏 */
.search-section {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #ffffff;
  gap: 20rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  color: #999;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.clear-icon {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx;
}

.filter-btn {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666;
  padding: 16rpx 20rpx;
}

.filter-icon {
  font-size: 20rpx;
  margin-left: 8rpx;
}

/* 统计卡片 */
.stats-section {
  padding: 20rpx 30rpx;
}

.stats-card {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.stats-item {
  flex: 1;
  text-align: center;
  border-right: 2rpx solid #f0f0f0;
}

.stats-item:last-child {
  border-right: none;
}

.stats-number {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.stats-number.active {
  color: #52c41a;
}

.stats-number.inactive {
  color: #999;
}

.stats-label {
  font-size: 24rpx;
  color: #666;
}

/* 班级列表 */
.class-list {
  padding: 0 30rpx;
}

.class-card {
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
  border-left: 4rpx solid rgba(124, 58, 237, 0.25);
  transition: all 250ms ease;
}

.class-card:active {
  border-left-color: #7C3AED;
  background: rgba(124, 58, 237, 0.03);
  transform: scale(0.98);
}

.class-main {
  padding: 30rpx;
}

.class-header {
  display: flex;
  margin-bottom: 24rpx;
}

.class-icon-bg {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #722ed1, #eb8cff);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.class-icon {
  font-size: 48rpx;
}

.class-info {
  flex: 1;
}

.class-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.class-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
}

.class-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.class-status.active {
  background: #e6f7e6;
  color: #52c41a;
}

.class-status.inactive {
  background: #f5f5f5;
  color: #999;
}

.class-course {
  font-size: 26rpx;
  color: #666;
}

.class-details {
  display: flex;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.detail-item {
  flex: 1;
  display: flex;
  align-items: center;
}

.detail-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.detail-text {
  font-size: 26rpx;
  color: #666;
}

.class-footer {
  display: flex;
}

.footer-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.footer-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #999;
}

.class-actions {
  background: #fafafa;
  padding: 16rpx 30rpx;
  display: flex;
  justify-content: flex-end;
}

.action-btn {
  font-size: 32rpx;
  color: #999;
  padding: 10rpx 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #999;
}

/* 添加按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: #722ed1;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(114, 46, 209, 0.4);
}

.fab-icon {
  font-size: 48rpx;
  color: #ffffff;
  font-weight: 300;
}

/* 筛选弹窗 */
.filter-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 32rpx;
  color: #999;
  padding: 10rpx;
}

.modal-body {
  padding: 30rpx;
  max-height: 600rpx;
  overflow-y: auto;
}

.filter-section {
  margin-bottom: 30rpx;
}

.filter-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-option {
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  border: 2rpx solid transparent;
}

.filter-option.active {
  color: #722ed1;
  background: #f9f0ff;
  border-color: #722ed1;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx 40rpx;
  gap: 20rpx;
}

.btn-reset {
  flex: 1;
  background: #f5f5f5;
  color: #666;
  border-radius: 40rpx;
  padding: 24rpx;
  font-size: 28rpx;
  border: none;
}

.btn-confirm {
  flex: 1;
  background: #722ed1;
  color: #ffffff;
  border-radius: 40rpx;
  padding: 24rpx;
  font-size: 28rpx;
  border: none;
}

/* 操作菜单 */
.action-sheet {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.action-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.action-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.action-header {
  padding: 40rpx 30rpx 30rpx;
  text-align: center;
  border-bottom: 2rpx solid #f5f5f5;
}

.action-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.action-subtitle {
  font-size: 24rpx;
  color: #999;
}

.action-list {
  padding: 20rpx 0;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.action-item:last-child {
  border-bottom: none;
}

.action-item.delete .action-text {
  color: #ff4d4f;
}

.action-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.action-text {
  font-size: 30rpx;
  color: #333;
}

.action-cancel {
  margin: 20rpx 30rpx;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  text-align: center;
  font-size: 30rpx;
  color: #666;
}

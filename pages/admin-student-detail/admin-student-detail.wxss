.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 基本信息卡片 */
.info-card {
  background: #ffffff;
  margin: 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.student-header {
  display: flex;
  align-items: flex-start;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7C3AED, #00aaff);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
}

.avatar-text {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
}

.student-main-info {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
}

.status-tag {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.status-tag.active {
  background: #e6f7e6;
  color: #52c41a;
}

.status-tag.inactive {
  background: #f5f5f5;
  color: #999;
}

.student-no {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  font-size: 22rpx;
  color: #fa8c16;
  background: #fff7e6;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.more-btn {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx 20rpx;
}

/* 详细信息卡片 */
.detail-card {
  background: #ffffff;
  margin: 0 30rpx 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.detail-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.detail-grid {
  display: flex;
  flex-wrap: wrap;
}

.detail-item {
  width: 50%;
  margin-bottom: 24rpx;
}

.detail-item.full-width {
  width: 100%;
}

.detail-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.detail-value {
  display: block;
  font-size: 28rpx;
  color: #333;
}

/* 家长信息 */
.parent-info {
  display: flex;
  align-items: center;
}

.parent-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.avatar-icon {
  font-size: 40rpx;
}

.parent-details {
  flex: 1;
}

.parent-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.parent-phone {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.parent-relation {
  font-size: 24rpx;
  color: #999;
}

.call-btn {
  width: 80rpx;
  height: 80rpx;
  background: #e6fffb;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.call-icon {
  font-size: 36rpx;
}

/* 空状态 */
.empty-info {
  padding: 40rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

/* 班级列表 */
.class-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.class-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fafafa;
  border-radius: 12rpx;
  border-left: 4rpx solid rgba(124, 58, 237, 0.25);
  transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
}

.class-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.class-info {
  flex: 1;
}

.class-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.class-meta {
  font-size: 24rpx;
  color: #999;
}

.arrow-icon {
  font-size: 28rpx;
  color: #999;
}

.class-item:active {
  border-left-color: #7C3AED;
  background: rgba(124, 58, 237, 0.03);
  transform: scale(0.98);
}

/* 成绩列表 */
.grade-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.grade-item {
  padding: 24rpx;
  background: #fafafa;
  border-radius: 12rpx;
}

.grade-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.grade-type {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.grade-date {
  font-size: 24rpx;
  color: #999;
}

.grade-body {
  display: flex;
  align-items: flex-start;
}

.score-section {
  margin-right: 30rpx;
}

.score-label {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 4rpx;
}

.score-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #7C3AED;
}

.comment-section {
  flex: 1;
}

.comment-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 考勤列表 */
.attendance-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.attendance-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fafafa;
  border-radius: 12rpx;
}

.attendance-date {
  font-size: 26rpx;
  color: #333;
}

.attendance-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.attendance-status.present {
  background: #e6f7e6;
  color: #52c41a;
}

.attendance-status.absent {
  background: #ffe6e6;
  color: #ff4d4f;
}

.attendance-status.leave {
  background: #fff7e6;
  color: #fa8c16;
}

/* 作业列表 */
.homework-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.homework-item {
  padding: 24rpx;
  background: #fafafa;
  border-radius: 12rpx;
}

.homework-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.homework-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.homework-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.homework-status.pending {
  background: #fff7e6;
  color: #fa8c16;
}

.homework-status.submitted {
  background: #e6f7ff;
  color: #1890ff;
}

.homework-status.graded {
  background: #e6f7e6;
  color: #52c41a;
}

.homework-meta {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.homework-result {
  padding-top: 12rpx;
  border-top: 2rpx solid #f0f0f0;
}

.result-score {
  font-size: 26rpx;
  color: #7C3AED;
  font-weight: 500;
}

/* 底部按钮 */
.bottom-actions {
  padding: 30rpx;
}

.btn-edit {
  width: 100%;
  background: #7C3AED;
  color: #ffffff;
  border-radius: 44rpx;
  padding: 28rpx;
  font-size: 30rpx;
  border: none;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  font-size: 28rpx;
  color: #999;
}

<view class="page-container">
  <!-- 未选择学生 -->
  <view class="no-student" wx:if="{{!currentStudent}}">
    <view class="no-student-card">
      <view class="no-student-icon">📈</view>
      <view class="no-student-text">暂无关联学生</view>
    </view>
  </view>

  <block wx:else>
    <!-- 整体进度 -->
    <view class="overview-section">
      <view class="overview-card">
        <view class="progress-circle">
          <view class="circle-bg"></view>
          <view class="circle-progress" style="transform: rotate({{overallStats.overallProgress * 3.6 - 90}}deg);"></view>
          <view class="circle-center">
            <view class="progress-value">{{overallStats.overallProgress}}%</view>
            <view class="progress-label">总进度</view>
          </view>
        </view>
        <view class="overview-stats">
          <view class="stat-item">
            <view class="stat-value">{{overallStats.completedSchedules}}/{{overallStats.totalSchedules}}</view>
            <view class="stat-label">已完成课时</view>
          </view>
          <view class="stat-item">
            <view class="stat-value green">{{overallStats.attendanceRate}}%</view>
            <view class="stat-label">出勤率</view>
          </view>
          <view class="stat-item">
            <view class="stat-value blue">{{overallStats.homeworkRate}}%</view>
            <view class="stat-label">作业完成</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 课程进度列表 -->
    <view class="section" wx:if="{{courseProgress.length > 0}}">
      <view class="section-title">各科学习进度</view>
      <view class="progress-list">
        <view class="progress-card" wx:for="{{courseProgress}}" wx:key="id">
          <view class="card-header">
            <view class="course-subject">{{item.subject}}</view>
            <view class="progress-percent {{item.progressRate >= 80 ? 'high' : item.progressRate >= 50 ? 'mid' : 'low'}}">{{item.progressRate}}%</view>
          </view>
          <view class="course-name">{{item.courseName}}</view>
          <view class="progress-bar">
            <view class="bar-bg"></view>
            <view class="bar-fill" style="width: {{item.progressRate}}%;"></view>
          </view>
          <view class="progress-info">
            <text>课时：{{item.completedSchedules}}/{{item.totalSchedules}}</text>
            <view class="today-tag" wx:if="{{item.todaySchedules > 0}}">今日有课</view>
          </view>
          <view class="detail-stats">
            <view class="detail-item">
              <text class="detail-label">出勤</text>
              <text class="detail-value {{item.attendanceRate >= 90 ? 'green' : item.attendanceRate >= 70 ? 'yellow' : 'red'}}">{{item.attendanceRate}}%</text>
            </view>
            <view class="detail-item">
              <text class="detail-label">作业</text>
              <text class="detail-value {{item.homeworkRate >= 90 ? 'green' : item.homeworkRate >= 70 ? 'yellow' : 'red'}}">{{item.homeworkRate}}%</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:else>
      <view class="empty-icon">📈</view>
      <view class="empty-title">暂无学习记录</view>
      <view class="empty-text">开始学习后会显示进度</view>
    </view>
  </block>
</view>

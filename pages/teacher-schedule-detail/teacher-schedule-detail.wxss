/* pages/teacher-schedule-detail/teacher-schedule-detail.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 状态卡片 */
.status-card {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 40rpx 30rpx;
  color: #fff;
}

.status-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.course-name {
  font-size: 36rpx;
  font-weight: bold;
  flex: 1;
}

.status-badge {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
}

.status-time {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
}

.date {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.time {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 信息区块 */
.info-section {
  background: #fff;
  margin: 20rpx 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.section-count {
  font-size: 26rpx;
  color: #999;
  font-weight: normal;
}

/* 信息列表 */
.info-list {
  margin-top: -10rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #999;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  max-width: 60%;
  text-align: right;
}

.info-value.link {
  color: #1890ff;
}

/* 学员列表 */
.student-list {
  margin-top: -10rpx;
}

.student-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.student-item:last-child {
  border-bottom: none;
}

.student-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.student-info {
  flex: 1;
}

.student-name {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.student-no {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.empty-student {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}

/* 操作按钮 */
.action-section {
  padding: 30rpx;
  margin-top: 20rpx;
}

.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  border-radius: 44rpx;
  margin-bottom: 20rpx;
}

.btn:last-child {
  margin-bottom: 0;
}

.btn-primary {
  background: #1890ff;
  color: #fff;
}

.btn-success {
  background: #52c41a;
  color: #fff;
}

.btn-warning {
  background: #faad14;
  color: #fff;
}

.btn-danger {
  background: #ff4d4f;
  color: #fff;
}

.btn-outline {
  background: #fff;
  color: #999;
  border: 2rpx solid #ddd;
}

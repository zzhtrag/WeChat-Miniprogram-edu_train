.page-container {
  min-height: 100vh;
  background: #F8FAFC;
  padding-bottom: 40rpx;
}

/* 头部 */
.header {
  background: #FFFFFF;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
}

.student-info {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.student-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1F2937;
}

.student-grade {
  font-size: 26rpx;
  color: #6B7280;
}

.summary-stats {
  display: flex;
  gap: 24rpx;
}

.s-stat {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.s-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #4F46E5;
}

.s-stat.excellent .s-num { color: #F59E0B; }
.s-stat.featured .s-num { color: #8B5CF6; }

.s-label {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 筛选 */
.filter-bar {
  padding: 12rpx 24rpx;
}

.filter-chip {
  display: inline-block;
  padding: 10rpx 24rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #6B7280;
  background: #FFFFFF;
  border: 1px solid #E5E7EB;
}

.filter-chip.active {
  background: #4F46E5;
  color: #FFFFFF;
  border-color: transparent;
  font-weight: 500;
}

/* 时间线 */
.timeline {
  padding: 0 24rpx;
}

.timeline-group {
  margin-bottom: 24rpx;
}

.timeline-month {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 16rpx;
  display: block;
}

.timeline-items {
  padding-left: 24rpx;
  border-left: 3px solid #E5E7EB;
}

.timeline-item {
  position: relative;
  margin-bottom: 16rpx;
  padding-left: 24rpx;
}

.timeline-dot {
  position: absolute;
  left: -29rpx;
  top: 28rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #4F46E5;
  border: 3px solid #FFFFFF;
}

.timeline-card {
  display: flex;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 16rpx;
  gap: 16rpx;
  border: 1px solid rgba(226, 232, 240, 0.5);
}

.card-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.card-thumb-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-title-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 6rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
  flex: 1;
  margin-right: 8rpx;
}

.card-badges {
  display: flex;
  gap: 6rpx;
  flex-shrink: 0;
}

.badge {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.badge.excellent {
  background: #FEF3C7;
  color: #D97706;
}

.badge.featured {
  background: #EDE9FE;
  color: #7C3AED;
}

.card-meta {
  font-size: 24rpx;
  color: #9CA3AF;
  display: block;
  margin-bottom: 6rpx;
}

.card-comment {
  font-size: 24rpx;
  color: #059669;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  opacity: 0.4;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 30rpx;
  color: #6B7280;
  display: block;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #9CA3AF;
}

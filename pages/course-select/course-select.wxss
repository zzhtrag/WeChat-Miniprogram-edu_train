.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 顶部标签栏 */
.tab-header {
  display: flex;
  align-items: center;
  background: #ffffff;
  padding: 0 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-scroll {
  flex: 1;
  height: 88rpx;
}

.tab-list {
  display: flex;
  height: 88rpx;
  align-items: center;
  white-space: nowrap;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  padding: 0 30rpx;
  font-size: 28rpx;
  color: #666;
  height: 88rpx;
  position: relative;
}

.tab-item.active {
  color: #00cccc;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #00cccc;
  border-radius: 2rpx;
}

/* 更多按钮 */
.tab-more {
  width: 80rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-left: 1rpx solid #f0f0f0;
}

.grid-icon {
  display: grid;
  grid-template-columns: 8rpx 8rpx;
  grid-template-rows: 8rpx 8rpx;
  gap: 4rpx;
}

.grid-dot {
  width: 8rpx;
  height: 8rpx;
  background: #00cccc;
  border-radius: 2rpx;
}

/* 课程列表 */
.course-list {
  padding: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

.empty-icon image {
  width: 100%;
  height: 100%;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 课程卡片 */
.course-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.course-basic {
  margin-bottom: 20rpx;
}

.course-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.course-meta {
  display: flex;
  gap: 16rpx;
}

.subject,
.grade {
  font-size: 24rpx;
  color: #00cccc;
  background: rgba(0, 204, 204, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.course-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.teacher-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.teacher-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
}

.teacher-name {
  font-size: 26rpx;
  color: #666;
}

.course-stats {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.stat {
  font-size: 24rpx;
  color: #999;
}

.remaining {
  font-size: 24rpx;
  color: #ff6b6b;
}

.full {
  font-size: 24rpx;
  color: #999;
}

.course-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.course-action {
  display: flex;
  justify-content: flex-end;
}

.enroll-btn {
  background: #00cccc;
  color: #ffffff;
  font-size: 28rpx;
  padding: 16rpx 40rpx;
  border-radius: 30rpx;
  border: none;
}

.enroll-btn.disabled {
  background: #ccc;
}

/* pages/teacher-student-detail/teacher-student-detail.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx;
  color: #999;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.btn-back {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
}

/* 详情内容 */
.detail-content {
  padding: 20rpx 30rpx 40rpx;
}

/* 学员信息卡片 */
.info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.student-avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 48rpx;
  color: #fff;
  font-weight: 500;
}

.student-basic {
  flex: 1;
  min-width: 0;
}

.student-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.student-name {
  font-size: 38rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
}

.student-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  background: #e6f7ff;
  color: #1890ff;
}

.student-status.inactive {
  background: #f5f5f5;
  color: #999;
}

.student-status.graduated {
  background: #f6ffed;
  color: #52c41a;
}

.student-no {
  font-size: 26rpx;
  color: #999;
}

.more-btn {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
  margin: -10rpx;
}

.card-body {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
}

.info-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  margin-right: 12rpx;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

.info-value.link {
  color: #1890ff;
}

/* 统计数据卡片 */
.stats-card {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-number {
  font-size: 44rpx;
  font-weight: 600;
  color: #1890ff;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #999;
}

.stats-divider {
  width: 1rpx;
  background: #f0f0f0;
  margin: 0 20rpx;
}

/* 标签页 */
.tab-section {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tab-header {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #1890ff;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #1890ff;
  border-radius: 3rpx;
}

.tab-content {
  padding: 30rpx;
  min-height: 400rpx;
}

/* 信息区域 */
.info-section {
  margin-bottom: 30rpx;
}

.info-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.info-list {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 10rpx 0;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.row-label {
  font-size: 28rpx;
  color: #666;
}

.row-value {
  font-size: 28rpx;
  color: #333;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  background: #fff7e6;
  color: #fa8c16;
  border-radius: 8rpx;
}

/* 课程列表 */
.empty-tips {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.course-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.course-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #fafafa;
  border-radius: 12rpx;
}

.course-info {
  flex: 1;
  border-left: 4rpx solid rgba(5, 150, 105, 0.25);
  transition: all 250ms ease;
}

.course-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.course-meta {
  display: flex;
  gap: 20rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #999;
}

.course-status {
  font-size: 26rpx;
  font-weight: 500;
}

.course-info:active {
  border-left-color: #059669;
  background: rgba(5, 150, 105, 0.03);
  transform: scale(0.98);
}

/* 考勤列表 */
.attendance-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.attendance-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fafafa;
  border-radius: 12rpx;
}

.attendance-date {
  font-size: 28rpx;
  color: #666;
  width: 180rpx;
}

.attendance-course {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.attendance-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

/* 成绩列表 */
.grade-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.grade-item {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 24rpx;
}

.grade-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.grade-course {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.grade-date {
  font-size: 24rpx;
  color: #999;
}

.grade-body {
  display: flex;
  align-items: center;
}

.grade-score {
  display: flex;
  align-items: baseline;
  margin-right: 30rpx;
}

.score-num {
  font-size: 48rpx;
  font-weight: 600;
  color: #1890ff;
}

.score-max {
  font-size: 28rpx;
  color: #999;
  margin-left: 4rpx;
}

.grade-info {
  flex: 1;
}

.grade-type {
  font-size: 26rpx;
  color: #666;
  display: block;
}

.grade-remark {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

/* 操作菜单 */
.action-sheet {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
}

.action-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.action-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
}

.action-list {
  padding: 10rpx 0;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
}

.action-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
}

.action-text {
  font-size: 30rpx;
  color: #333;
}

.action-cancel {
  text-align: center;
  padding: 30rpx;
  background: #fafafa;
  font-size: 30rpx;
  color: #666;
}

/* 作品集 */
.portfolio-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.portfolio-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  gap: 16rpx;
  border: 1px solid #F0F0F0;
  border-left: 4rpx solid rgba(5, 150, 105, 0.25);
  transition: all 250ms ease;
}

.portfolio-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.portfolio-thumb-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.portfolio-info {
  flex: 1;
  min-width: 0;
}

.portfolio-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
  display: block;
  margin-bottom: 6rpx;
}

.portfolio-meta {
  display: flex;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.portfolio-category {
  font-size: 22rpx;
  color: #059669;
}

.portfolio-date {
  font-size: 22rpx;
  color: #9CA3AF;
}

.portfolio-badges {
  display: flex;
  gap: 8rpx;
}

.p-badge {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.p-badge.excellent {
  background: #FEF3C7;
  color: #D97706;
}

.p-badge.featured {
  background: #EDE9FE;
  color: #7C3AED;
}

.portfolio-item:active {
  border-left-color: #059669;
  background: rgba(5, 150, 105, 0.03);
  transform: scale(0.98);
}

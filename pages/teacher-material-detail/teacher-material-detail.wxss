.page-container {
  min-height: 100vh;
  background: #F8FAFC;
  padding-bottom: 140rpx;
}

/* 预览区 */
.preview-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 24rpx;
  background: #FFFFFF;
  margin-bottom: 16rpx;
}

.preview-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.preview-file-icon {
  font-size: 56rpx;
}

.preview-file-name {
  font-size: 28rpx;
  color: #374151;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.preview-hint {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 信息卡片 */
.info-card {
  background: #FFFFFF;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
}

.info-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1F2937;
  display: block;
  margin-bottom: 16rpx;
}

.info-meta {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.meta-chip {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.info-desc {
  font-size: 28rpx;
  color: #6B7280;
  line-height: 1.6;
}

/* 详情卡片 */
.detail-card {
  background: #FFFFFF;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1px solid #F3F4F6;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 26rpx;
  color: #9CA3AF;
}

.detail-value {
  font-size: 26rpx;
  color: #374151;
}

/* 标签 */
.tags-card {
  background: #FFFFFF;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.card-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 16rpx;
  display: block;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  font-size: 24rpx;
  color: #6B7280;
  background: #F3F4F6;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

/* 分享卡片 */
.share-card {
  background: #FFFFFF;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.share-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.share-count {
  font-size: 24rpx;
  color: #9CA3AF;
}

.share-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.share-item {
  padding: 16rpx 20rpx;
  background: #ECFDF5;
  border-radius: 12rpx;
}

.share-class-name {
  font-size: 26rpx;
  color: #059669;
  font-weight: 500;
}

.share-empty {
  text-align: center;
  padding: 20rpx;
}

.share-empty-text {
  font-size: 26rpx;
  color: #9CA3AF;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  border-top: 1px solid #F1F5F9;
  z-index: 10;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.edit {
  background: #EFF6FF;
  color: #3B82F6;
}

.action-btn.share {
  background: linear-gradient(135deg, #059669, #10B981);
  color: #FFFFFF;
}

.action-btn.delete {
  background: #FEF2F2;
  color: #EF4444;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.share-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 40rpx 40rpx 0 0;
  z-index: 101;
  max-height: 70vh;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1px solid #F1F5F9;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
}

.modal-close {
  font-size: 40rpx;
  color: #9CA3AF;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-body {
  padding: 24rpx 30rpx;
  max-height: 50vh;
  overflow-y: auto;
}

.class-check-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  gap: 16rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  border: 2px solid #D1D5DB;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #FFFFFF;
}

.checkbox.checked {
  background: #059669;
  border-color: #059669;
}

.class-name {
  font-size: 28rpx;
  color: #374151;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 30rpx;
  border-top: 1px solid #F1F5F9;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.modal-btn.cancel {
  background: #F3F4F6;
  color: #6B7280;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #059669, #10B981);
  color: #FFFFFF;
}

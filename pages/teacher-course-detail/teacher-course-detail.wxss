.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  font-size: 28rpx;
  color: #999;
}

.info-card {
  background: #ffffff;
  margin: 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.course-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.detail-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.detail-item {
  display: flex;
  flex-direction: column;
}

.detail-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.detail-value {
  font-size: 28rpx;
  color: #333;
}

.course-desc {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.desc-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.section {
  margin: 0 30rpx 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

.class-list, .schedule-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.class-item {
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.class-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.class-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.status-tag {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.status-tag.active {
  background: #e6f7e6;
  color: #52c41a;
}

.status-tag.inactive, .status-tag.ended {
  background: #f5f5f5;
  color: #999;
}

.class-meta {
  font-size: 24rpx;
  color: #999;
}

.class-meta text {
  margin-right: 20rpx;
}

.schedule-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.schedule-date {
  font-size: 28rpx;
  color: #333;
  width: 180rpx;
}

.schedule-info {
  flex: 1;
}

.schedule-time {
  font-size: 26rpx;
  color: #666;
  display: block;
}

.schedule-class {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.schedule-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.schedule-status.scheduled {
  background: #e6f7ff;
  color: #1677ff;
}

.schedule-status.completed {
  background: #e6f7e6;
  color: #52c41a;
}

.schedule-status.cancelled {
  background: #fff1f0;
  color: #ff4d4f;
}

.empty-tips {
  text-align: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: #999;
}

<view class="page-container">
  <!-- 报告头部 -->
  <view class="report-header bg-gradient-primary stagger-1">
    <view class="header-top">
      <text class="header-label">试听体验报告</text>
      <view class="tag {{report.status === 'confirmed' ? 'tag-success' : report.status === 'expired' ? 'tag-muted' : 'tag-warning'}}">
        {{report.status === 'confirmed' ? '已确认' : report.status === 'expired' ? '已过期' : '待确认'}}
      </view>
    </view>
    <text class="header-student">{{report.student_name}}的体验报告</text>
    <text class="header-meta">{{report.class_name}} · {{report.teacher_name}}老师</text>
  </view>

  <block wx:if="{{report}}">
    <!-- 课堂表现 -->
    <view class="section stagger-2">
      <view class="section-header">
        <view class="section-icon icon-box icon-box-primary icon-box-sm">
          <text>🎯</text>
        </view>
        <text class="section-title">课堂表现</text>
      </view>
      <view class="performance-card card">
        <view class="score-ring">
          <view class="ring-value">
            <text class="ring-num">{{report.performance_score}}</text>
            <text class="ring-label">综合评分</text>
          </view>
        </view>
        <view class="performance-details">
          <view class="detail-item" wx:for="{{report.performance_details}}" wx:key="label">
            <text class="detail-label">{{item.label}}</text>
            <view class="detail-bar-track">
              <view class="detail-bar-fill" style="width: {{item.percent}}%; background: var(--primary)"></view>
            </view>
            <text class="detail-value">{{item.value}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 兴趣评估 -->
    <view class="section stagger-3">
      <view class="section-header">
        <view class="section-icon icon-box icon-box-warning icon-box-sm">
          <text>💡</text>
        </view>
        <text class="section-title">兴趣评估</text>
      </view>
      <view class="interest-card card">
        <view class="interest-level">
          <text class="level-label">兴趣程度</text>
          <view class="level-dots">
            <view class="level-dot {{index < report.interest_level ? 'active' : ''}}" wx:for="{{5}}" wx:key="index"></view>
          </view>
          <text class="level-text">{{interestLabels[report.interest_level - 1]}}</text>
        </view>
        <text class="interest-desc" wx:if="{{report.interest_comment}}">{{report.interest_comment}}</text>
      </view>
    </view>

    <!-- 能力分析 -->
    <view class="section stagger-4">
      <view class="section-header">
        <view class="section-icon icon-box icon-box-success icon-box-sm">
          <text>📊</text>
        </view>
        <text class="section-title">能力分析</text>
      </view>
      <view class="ability-card card">
        <view class="ability-item" wx:for="{{report.ability_analysis}}" wx:key="dimension">
          <view class="ability-header">
            <text class="ability-name">{{item.dimension}}</text>
            <text class="ability-level {{item.level === '优秀' ? 'text-success' : item.level === '良好' ? 'text-primary' : 'text-secondary'}}">{{item.level}}</text>
          </view>
          <view class="ability-bar-track">
            <view class="ability-bar-fill" style="width: {{item.percent}}%; background: {{item.level === '优秀' ? 'var(--success)' : item.level === '良好' ? 'var(--primary)' : 'var(--text-muted)'}}"></view>
          </view>
          <text class="ability-desc" wx:if="{{item.comment}}">{{item.comment}}</text>
        </view>
      </view>
    </view>

    <!-- 推荐课程 -->
    <view class="section stagger-5" wx:if="{{report.recommended_course}}">
      <view class="section-header">
        <view class="section-icon icon-box icon-box-danger icon-box-sm">
          <text>📚</text>
        </view>
        <text class="section-title">推荐课程方案</text>
      </view>
      <view class="recommend-card card card-primary">
        <view class="recommend-top">
          <text class="recommend-name">{{report.recommended_course.name}}</text>
          <text class="recommend-match">匹配度 {{report.recommended_course.match_percent}}%</text>
        </view>
        <text class="recommend-desc">{{report.recommended_course.description}}</text>
        <view class="recommend-details">
          <text class="recommend-detail">🕐 {{report.recommended_course.duration}}</text>
          <text class="recommend-detail">📅 {{report.recommended_course.schedule}}</text>
        </view>
      </view>
    </view>

    <!-- 限时优惠 -->
    <view class="section stagger-6" wx:if="{{report.discount_info && report.status !== 'expired'}}">
      <view class="discount-card card">
        <view class="discount-badge">
          <text class="discount-icon">🎁</text>
          <text class="discount-title">限时优惠</text>
        </view>
        <text class="discount-text">{{report.discount_info.description}}</text>
        <view class="discount-deadline">
          <text class="deadline-label">优惠截止</text>
          <text class="deadline-value">{{report.discount_info.valid_until}}</text>
        </view>
        <view class="discount-countdown" wx:if="{{countdown}}">
          <text class="countdown-text">{{countdown}}</text>
        </view>
      </view>
    </view>

    <!-- 教师评语 -->
    <view class="section" wx:if="{{report.teacher_comment}}">
      <view class="section-header">
        <view class="section-icon icon-box icon-box-primary icon-box-sm">
          <text>💬</text>
        </view>
        <text class="section-title">老师的话</text>
      </view>
      <view class="comment-card card">
        <view class="comment-quote">"</view>
        <text class="comment-text">{{report.teacher_comment}}</text>
        <view class="comment-quote end">"</view>
        <text class="comment-author">—— {{report.teacher_name}}老师</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-section" wx:if="{{report.status === 'sent'}}">
      <view class="btn-primary confirm-btn" bindtap="confirmEnrollment">
        确认报名
      </view>
      <view class="btn-ghost share-btn" bindtap="shareReport">
        分享给家人
      </view>
    </view>

    <view class="action-section" wx:elif="{{report.status === 'confirmed'}}">
      <view class="confirmed-badge">
        <text class="confirmed-icon">✅</text>
        <text class="confirmed-text">已确认报名</text>
      </view>
    </view>

    <view class="action-section expired" wx:elif="{{report.status === 'expired'}}">
      <text class="expired-text">此优惠已过期，请联系机构咨询最新课程</text>
      <view class="btn-outline contact-btn" bindtap="contactSchool">
        联系机构
      </view>
    </view>
  </block>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && !report}}">
    <view class="empty-state-icon">📋</view>
    <text class="empty-state-title">报告不存在</text>
    <text class="empty-state-text">请确认链接是否正确</text>
  </view>
</view>